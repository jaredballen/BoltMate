---
import Base from "../layouts/Base.astro";
import { loadPricing } from "../lib/pricing.ts";

const pricing = await loadPricing();
const TRIAL_DAYS = 14;

const faq = [
  {
    q: "Is this really one-time?",
    a: "Yes. Pay once, use it on every Mac or PC you sign into with the same account. No subscription, no per-seat fee — every future BoltMate update is included.",
  },
  {
    q: "How many computers can I use it on?",
    a: "Every machine you sign into. The license is bound to your account, not to a serial number or a per-seat count. Use it on your work Mac, your home Windows desktop, and a laptop — all yours.",
  },
  {
    q: "Do I have to enter a license key?",
    a: "No. Sign in inside the desktop app with the same OAuth provider you used at checkout (Apple or Google) and the license activates automatically. There are no keys anywhere.",
  },
  {
    q: "Which sign-ins are supported?",
    a: "Apple and Google today. We picked the two that nearly everyone already has and that don't require yet-another-password. More providers may land later.",
  },
];
---

<Base title="Pricing — BoltMate" pathname="/pricing">
  <!-- ===== HEADLINE ===== -->
  <section class="pricing-headline">
    <div class="container">
      <p class="eyebrow">PRICING</p>
      <h1>Try it free. Buy it once.</h1>
      <p class="lede">
        Start with a {TRIAL_DAYS}-day free trial — every feature, no card.
        When you're ready, the lifetime license is a one-time {pricing.amount}.
      </p>
    </div>
  </section>

  <!-- ===== PRICE CARDS ===== -->
  <section class="pricing-cards">
    <div class="container">
      <div class="price-cards">
        <article class="price-card price-card-light">
          <div class="price-card-title">Free trial</div>
          <div class="price-card-amount">
            <span class="price-card-num">$0</span>
            <span class="price-card-unit">for {TRIAL_DAYS} days</span>
          </div>
          <p class="price-card-body">Every feature, unlocked. No card required — just download and go.</p>
          <ul class="price-card-list">
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>All cross-device fan-out</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>macOS and Windows</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>No commitment — decide later</li>
          </ul>
          <a href="/checkout?mode=trial" class="btn btn-secondary-lg price-card-cta">Start free trial</a>
        </article>
        <article class="price-card price-card-dark" id="buy">
          <span class="price-card-pill">ONE-TIME</span>
          <div class="price-card-title-light">Lifetime license</div>
          <div class="price-card-amount">
            <span class="price-card-num-light">{pricing.amount}</span>
            <span class="price-card-unit-light">once</span>
          </div>
          <p class="price-card-body-light">Buy once. Yours forever — every future update included.</p>
          <ul class="price-card-list-light">
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Everything in the trial</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Licensed to your account — no keys</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Use on all your Macs and PCs</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Every future update</li>
          </ul>
          <a href="/checkout" class="btn btn-green price-card-cta">Buy lifetime — {pricing.amount}</a>
        </article>
      </div>
      <p class="pricing-currency-note">
        {pricing.fromFallback
          ? "Showing default price — connect Stripe to fetch live."
          : `Charged via Stripe in ${pricing.currency}.`}
      </p>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-intro">
        <p class="eyebrow">QUESTIONS</p>
        <h2 class="section-h">Common things people ask.</h2>
      </div>
      <dl class="faq-list">
        {faq.map((item) => (
          <div class="faq-item">
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Base>

<style>
  .pricing-headline {
    padding: 84px 0 12px;
    text-align: center;
  }
  .pricing-headline h1 {
    margin: 14px 0 0;
    font-weight: 700;
    font-size: clamp(36px, 5.5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #161616;
  }
  .pricing-headline .lede {
    margin: 18px auto 0;
    max-width: 56ch;
    font-size: 17px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }

  .pricing-cards {
    padding: 48px 0 84px;
  }
  .price-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    max-width: 760px;
    margin: 0 auto;
    align-items: stretch;
  }
  @media (max-width: 760px) {
    .price-cards { grid-template-columns: 1fr; }
  }
  .price-card {
    padding: 30px 28px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .price-card-light { background: #fff; border: 1px solid #e6e6ea; }
  .price-card-dark { background: #1c1c1e; color: #fff; box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.55); }
  .price-card-title { font-weight: 620; font-size: 16px; line-height: 1; color: #161616; }
  .price-card-title-light { font-weight: 620; font-size: 16px; line-height: 1; color: #f5f5f7; }
  .price-card-amount { margin: 16px 0 4px; display: flex; align-items: baseline; gap: 7px; }
  .price-card-num { font-weight: 700; font-size: 42px; line-height: 1; letter-spacing: -0.03em; color: #161616; }
  .price-card-num-light { font-weight: 700; font-size: 42px; line-height: 1; letter-spacing: -0.03em; color: #fff; }
  .price-card-unit { font-weight: 450; font-size: 14px; line-height: 1; color: var(--bm-fg-tertiary); }
  .price-card-unit-light { font-weight: 450; font-size: 14px; line-height: 1; color: #8e8e93; }
  .price-card-body { margin: 8px 0 0; font-size: 13.5px; line-height: 1.5; color: #6e6e73; }
  .price-card-body-light { margin: 8px 0 0; font-size: 13.5px; line-height: 1.5; color: #a6a6ac; }
  .price-card-list, .price-card-list-light {
    list-style: none; padding: 0; margin: 22px 0 24px;
    display: flex; flex-direction: column; gap: 11px;
  }
  .price-card-list li, .price-card-list-light li {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 13.5px; line-height: 1.4;
  }
  .price-card-list li { color: #3a3a3c; }
  .price-card-list-light li { color: #e3e3e6; }
  .price-card-list svg, .price-card-list-light svg { margin-top: 1px; flex: none; }
  .price-card-pill {
    position: absolute; top: 22px; right: 24px;
    padding: 4px 10px; border-radius: 20px;
    background: var(--bm-green-tint-14);
    color: #bdf58c;
    font-family: var(--bm-font-mono);
    font-weight: 700; font-size: 10px; letter-spacing: 0.05em;
  }
  .price-card-cta { margin-top: auto; width: 100%; }

  .pricing-currency-note {
    margin: 24px 0 0;
    text-align: center;
    font-family: var(--bm-font-mono);
    font-size: 12px;
    color: var(--bm-fg-tertiary);
  }

  .faq-section {
    background: var(--bm-bg-soft);
    border-top: 1px solid var(--bm-stroke);
    padding: 84px 0;
  }
  .faq-intro { max-width: 640px; }
  .faq-intro .eyebrow { margin-bottom: 14px; }
  .section-h {
    margin: 0;
    font-weight: 660;
    font-size: clamp(28px, 4vw, 36px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #161616;
  }
  .faq-list {
    display: grid;
    gap: 12px;
    margin: 32px 0 0;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--bm-stroke);
    border-radius: 14px;
    padding: 22px 24px;
  }
  .faq-item dt {
    font-weight: 620;
    font-size: 15px;
    line-height: 1.3;
    color: #161616;
    margin: 0 0 8px;
  }
  .faq-item dd {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: #5a5a5f;
  }
</style>
