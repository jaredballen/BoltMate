---
import Base from "../layouts/Base.astro";
---

<Base title="Not found — BoltMate" pathname="/404">
  <section class="section nf">
    <div class="container nf-inner">
      <p class="eyebrow">404</p>
      <h1>This page is on a different host.</h1>
      <p>Press Easy-Switch on the keyboard, or go back home.</p>
      <a href="/" class="btn btn-primary">Back to BoltMate</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 60vh;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 64px 0;
  }
  .nf-inner { max-width: 520px; }
  .nf h1 {
    margin: 14px 0 0;
    font-weight: 700;
    font-size: clamp(28px, 4.5vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #161616;
  }
  .nf p {
    font-size: 17px;
    color: var(--bm-fg-secondary);
    margin: 16px 0 28px;
  }
</style>
