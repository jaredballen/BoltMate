<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="using:BoltMate.App"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="BoltMate.App.SettingsWindow"
        Width="820" Height="560"
        MinWidth="680" MinHeight="460"
        Title="BoltMate Settings"
        WindowStartupLocation="CenterScreen">

    <!--
        Win11-style settings shell:
        FANavigationView ("FA" = FluentAvalonia's prefix to disambiguate from
        Avalonia's stock NavigationView) on the left with three items. Each
        NavigationView item has a tag we use in code-behind to switch the
        Content panel via the SelectionChanged event.

        Mac Mica is NOT enabled (Mica is Windows-only and not worth the
        per-platform code-behind plumbing for v1).
    -->
    <Grid>
        <ui:FANavigationView x:Name="MainNav"
                             PaneDisplayMode="Left"
                             IsBackButtonVisible="False"
                             IsSettingsVisible="False"
                             IsPaneToggleButtonVisible="False"
                             OpenPaneLength="200"
                             AlwaysShowHeader="False">
            <ui:FANavigationView.MenuItems>
                <ui:FANavigationViewItem x:Name="StatusNavItem"
                                         Content="Status"
                                         Tag="status">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Globe" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
                <ui:FANavigationViewItem x:Name="AboutNavItem"
                                         Content="About"
                                         Tag="about">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Important" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
                <ui:FANavigationViewItem x:Name="LicenseNavItem"
                                         Content="License"
                                         Tag="license">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Document" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
            </ui:FANavigationView.MenuItems>

            <!--
                Content host. The three pages are stacked in a Grid; only one
                is visible at a time. Selection logic lives in code-behind so
                we can keep the existing OpenTo(tab) API.
            -->
            <Grid>

                <!-- ======================= STATUS ======================= -->
                <Grid x:Name="StatusPage" Margin="20" RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="Status" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                            Online devices on this machine, the local network access state, and any peers reachable on the LAN.
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="16">

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="This machine" FontSize="14" FontWeight="SemiBold" />
                                    <ItemsControl x:Name="LocalDevicesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="app:SettingsWindow+LocalDeviceRow">
                                                <Border Padding="8" Margin="0,0,0,4"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding SubLine}"
                                                                   Foreground="#9AA0A6" FontSize="11"
                                                                   FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="LocalEmptyLine"
                                               Text="No devices currently linked up."
                                               Foreground="#9AA0A6" FontSize="12" IsVisible="False" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Network access" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="NetworkPermissionLine"
                                               Foreground="#B5BAC2" FontSize="12" />
                                    <Button x:Name="OpenNetworkSettingsButton"
                                            Content="Open Privacy Settings"
                                            Click="OnOpenNetworkSettings"
                                            IsVisible="False" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Peers" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="PeersStateLine"
                                               Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                    <ItemsControl x:Name="PeersList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="app:SettingsWindow+PeerRow">
                                                <Border Padding="8" Margin="0,0,0,4"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4">
                                                    <StackPanel Spacing="3">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                            <TextBlock Grid.Column="1" Text="{Binding LastSeen}" Foreground="#9AA0A6" FontSize="11" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding MetaLine}"
                                                                   Foreground="#9AA0A6" FontSize="11"
                                                                   FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                        <ItemsControl ItemsSource="{Binding Devices}" Margin="6,2,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="app:SettingsWindow+PeerDeviceRow">
                                                                    <TextBlock Text="{Binding Line}"
                                                                               Foreground="#B5BAC2" FontSize="11"
                                                                               FontFamily="JetBrains Mono,Menlo,Consolas,monospace" Margin="0,1" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="PeersOverflowLine"
                                               Foreground="#9AA0A6" FontSize="11" IsVisible="False" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= ABOUT ======================= -->
                <Grid x:Name="AboutPage" Margin="20" IsVisible="False">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="BoltMate" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock x:Name="AboutVersionLine" Foreground="#9AA0A6" FontSize="12" />
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Updates" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Last checked:" Foreground="#9AA0A6" VerticalAlignment="Center" />
                                        <TextBlock x:Name="LastCheckedLine" Text="never" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="CheckNowButton" Content="Check for updates" Click="OnCheckForUpdatesNow" />
                                    </StackPanel>
                                    <TextBlock x:Name="UpdateStatusLine"
                                               Foreground="#B5BAC2" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox x:Name="LaunchAtLoginToggle"
                                              Content="Launch BoltMate at login"
                                              IsCheckedChanged="OnLaunchAtLoginChanged" />
                                    <TextBlock x:Name="LaunchAtLoginDetail"
                                               Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Privacy" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox x:Name="TelemetryToggle"
                                              Content="Send anonymous diagnostics"
                                              IsCheckedChanged="OnTelemetryChanged" />
                                    <TextBlock Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                        Off by default. When on, error reports and de-identified usage counts go to Azure App Insights.
                                        No device serials, key strokes, or file paths are ever sent.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Diagnostics" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open logs folder" Click="OnOpenLogsFolder" />
                                    </StackPanel>
                                    <TextBlock x:Name="LogsPathLine" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= LICENSE ======================= -->
                <Grid x:Name="LicensePage" Margin="20" IsVisible="False">
                    <StackPanel Spacing="16">
                        <TextBlock Text="License" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Licensing — coming soon" Foreground="#B5BAC2" FontSize="13" />
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Activation key" FontSize="14" FontWeight="SemiBold" />
                                <TextBox IsEnabled="False" Text="" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Activate" IsEnabled="False" />
                                </StackPanel>
                                <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                    Licensing is not yet available. The current build runs all features without an activation key.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </ui:FANavigationView>
    </Grid>
</Window>
