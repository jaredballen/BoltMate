<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LogiPlusSwitcher.App.Dialogs.AlertWindow"
        Width="440" Height="180"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        Title="LogiPlusSwitcher">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" x:Name="HeaderText" FontWeight="Bold" Margin="0,0,0,8" />
        <TextBlock Grid.Row="1" x:Name="BodyText" Foreground="#CCC" TextWrapping="Wrap" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OnOk" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
