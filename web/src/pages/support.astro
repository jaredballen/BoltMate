---
import Base from "../layouts/Base.astro";
---

<Base title="Support — BoltMate" pathname="/support">
  <section class="section support-hero">
    <div class="container">
      <p class="eyebrow">Support</p>
      <h1>Tell us what broke.</h1>
      <p class="lede">
        Anything from "device didn't follow" to "I bought it but the
        download won't run". We read every message — replies come from
        a human, not a queue bot.
      </p>
    </div>
  </section>

  <section class="section support-form-section">
    <div class="container support-grid">
      <form id="support-form" novalidate>
        <div class="row">
          <label for="email">Your email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="row">
          <label for="name">Your name <span>optional</span></label>
          <input id="name" name="name" type="text" autocomplete="name" />
        </div>
        <div class="row">
          <label for="subject">Subject</label>
          <input id="subject" name="subject" type="text" />
        </div>
        <div class="row">
          <label for="message">What's going on?</label>
          <textarea id="message" name="message" rows="6" required></textarea>
          <p class="row-hint">
            Include the OS + machine, what you were doing, and what
            actually happened. If you can grab the BoltMate logs from
            the app's Settings &rarr; Support tab, drop the bundle URL
            in here too.
          </p>
        </div>

        <div class="actions">
          <button type="submit" class="btn btn-primary" id="submit-btn">Send to support</button>
          <p class="status" id="status" role="status" aria-live="polite"></p>
        </div>
      </form>

      <aside class="support-tips">
        <h2>Faster ways to get unstuck</h2>
        <p>
          Most BoltMate issues are HID permissions, firewall rules, or
          one machine on a different LAN segment. Before sending a
          ticket, try:
        </p>
        <ul>
          <li>Check macOS Settings &rarr; Privacy &amp; Security &rarr; Input Monitoring includes BoltMate.</li>
          <li>Check Windows Defender Firewall allows BoltMate on private networks.</li>
          <li>Confirm all machines are on the same network — VPNs and guest networks usually block multicast.</li>
        </ul>
        <p class="aside-fineprint">
          Reply directly to the email we send you when you submit.
          That's the fastest channel.
        </p>
      </aside>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("support-form") as HTMLFormElement | null;
  const status = document.getElementById("status") as HTMLParagraphElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  if (form && status && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      status.className = "status";

      const data = new FormData(form);
      const email = (data.get("email") || "").toString().trim();
      const message = (data.get("message") || "").toString().trim();
      if (!email || !message) {
        status.textContent = "Email and message are required.";
        status.classList.add("error");
        return;
      }

      const payload = {
        email,
        name: (data.get("name") || "").toString().trim() || undefined,
        subject: (data.get("subject") || "").toString().trim() || "Support request",
        message,
        source: "site",
      };

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const resp = await fetch("/api/support", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (resp.ok || resp.status === 202) {
          form.reset();
          status.textContent = "Got it — we'll reply at " + email + " within a day.";
          status.classList.add("ok");
        } else {
          const body = await resp.text().catch(() => "");
          status.textContent = "Couldn't send: " + (body || resp.statusText);
          status.classList.add("error");
        }
      } catch (err) {
        status.textContent = "Network error — try again in a minute.";
        status.classList.add("error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send to support";
      }
    });
  }
</script>

<style>
  .support-hero { padding-block: 72px 16px; }
  .support-hero h1 { max-width: 18ch; }
  .lede { font-size: 1.125rem; color: var(--bm-fg-secondary); max-width: 56ch; }

  .support-grid {
    display: grid;
    gap: 36px;
    grid-template-columns: 1.4fr 1fr;
  }
  @media (max-width: 880px) {
    .support-grid { grid-template-columns: 1fr; }
  }

  form { display: grid; gap: 18px; }
  .row { display: grid; gap: 6px; }
  label {
    font-size: 0.9rem;
    color: var(--bm-fg-secondary);
  }
  label span {
    margin-left: 6px;
    color: var(--bm-fg-tertiary);
    font-weight: 400;
  }
  input, textarea {
    background: var(--bm-bg-elev);
    color: var(--bm-fg);
    border: 1px solid var(--bm-stroke-strong);
    border-radius: var(--bm-radius-sm);
    padding: 12px 14px;
    font: inherit;
    font-family: var(--bm-font-text);
    resize: vertical;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--bm-green);
    box-shadow: 0 0 0 3px var(--bm-green-tint-20);
  }
  textarea { min-height: 140px; }
  .row-hint {
    margin: 6px 0 0;
    font-size: 0.82rem;
    color: var(--bm-fg-tertiary);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .status { margin: 0; font-size: 0.92rem; color: var(--bm-fg-secondary); }
  .status.ok { color: var(--bm-green); }
  .status.error { color: #ff7a6a; }

  .support-tips {
    background: var(--bm-bg-elev);
    border: 1px solid var(--bm-stroke);
    border-radius: var(--bm-radius-md);
    padding: 22px 24px;
    align-self: start;
  }
  .support-tips h2 { font-size: 1.05rem; }
  .support-tips ul {
    list-style: none;
    padding: 0;
    margin: 14px 0;
    display: grid;
    gap: 10px;
  }
  .support-tips ul li {
    padding-left: 18px;
    position: relative;
    color: var(--bm-fg-secondary);
  }
  .support-tips ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--bm-green);
  }
  .aside-fineprint {
    margin: 0;
    font-size: 0.82rem;
    color: var(--bm-fg-tertiary);
  }
</style>
