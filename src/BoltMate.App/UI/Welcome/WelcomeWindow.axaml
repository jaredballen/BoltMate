<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:BoltMate.App.UI"
        x:Class="BoltMate.App.UI.WelcomeWindow"
        x:DataType="vm:WelcomeViewModel"
        Width="660" Height="508"
        MinWidth="540" MinHeight="440"
        Title="Welcome to BoltMate"
        CanResize="True"
        WindowStartupLocation="CenterScreen">

    <!--
        Welcome / setup wizard.

        Layout per June 2026 design handoff §1:
          [ 208 px brand rail  | flex content pane ]
          rail (always dark): logo lockup → "Step N of M" → vertical
            step tracker → "Nothing here talks to the internet…" footer.
          content pane (theme-aware): one page visible at a time, bound
            to the VM's CurrentPage state. 3 px green spine on the
            Welcome step only.

        State machine lives in WelcomeViewModel. Page transitions never
        touch Avalonia handles — they mutate VM properties; the right-
        column Grid binds IsVisible per page to the matching ShowXxx
        property.

        Window size: 660×508 is the design default; resizable with
        a sane minimum since the user said sizes aren't strict.
    -->

    <Grid ColumnDefinitions="208,*"
          Background="{DynamicResource AppBackgroundBrush}">

        <!-- ====================================================== -->
        <!-- LEFT BRAND RAIL                                        -->
        <!-- ====================================================== -->
        <Border Grid.Column="0"
                Background="{DynamicResource BrandRailBackgroundBrush}">
            <Panel>
                <!-- Faint green radial glow at the top of the rail
                     (handoff §1 brand-rail spec). 60 % opacity centre,
                     faded to fully transparent by the lower half. -->
                <Border IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="50%,0%"
                                             GradientOrigin="50%,0%"
                                             RadiusX="80%" RadiusY="55%">
                            <GradientStop Offset="0"   Color="#3399FF55" />
                            <GradientStop Offset="0.55" Color="#1499FF55" />
                            <GradientStop Offset="1"   Color="#0099FF55" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
                <Grid RowDefinitions="Auto,Auto,*" Margin="20,22,20,22">

                <!-- Logo lockup -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8"
                            Background="{DynamicResource BrandBlackTileBrush}">
                        <Image Source="avares://BoltMate/Assets/BoltMate_logo.png"
                               Width="19" Height="19"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="BoltMate"
                               Foreground="White"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Step caption -->
                <TextBlock Grid.Row="1"
                           Text="{Binding StepCaption}"
                           Foreground="{DynamicResource BrandRailUpcomingTextBrush}"
                           FontSize="11"
                           Margin="2,22,0,12" />

                <!-- Step tracker -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WizardStep">
                            <!-- Each row is a Panel that overlays an
                                 active-tint background Border (visible only
                                 when IsActive) under the content row. No
                                 converters / MultiBindings needed. -->
                            <Panel>
                                <Border CornerRadius="8"
                                        IsVisible="{Binding IsActive}"
                                        Background="{DynamicResource BrandRailActiveBackgroundBrush}" />
                                <Grid Margin="10,8" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <!-- Indicator (Active / Done / Upcoming) -->
                                    <Panel Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center">
                                        <!-- Active: hollow green ring + 6 px dot -->
                                        <Ellipse IsVisible="{Binding IsActive}"
                                                 StrokeThickness="2"
                                                 Stroke="{DynamicResource BrandGreenBrush}" />
                                        <Ellipse IsVisible="{Binding IsActive}"
                                                 Width="6" Height="6"
                                                 Fill="{DynamicResource BrandGreenBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <!-- Done: solid green chip + dark check -->
                                        <Ellipse IsVisible="{Binding IsDone}"
                                                 Fill="{DynamicResource BrandGreenBrush}" />
                                        <ui:FASymbolIcon IsVisible="{Binding IsDone}"
                                                         Symbol="Accept" FontSize="10"
                                                         Foreground="{DynamicResource BrandBlackTileBrush}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                                        <!-- Upcoming: hollow grey ring -->
                                        <Ellipse IsVisible="{Binding IsUpcoming}"
                                                 StrokeThickness="2"
                                                 Stroke="{DynamicResource BrandRailUpcomingRingBrush}" />
                                    </Panel>

                                    <!-- Label — colour + weight by state via triple TextBlock with
                                         IsVisible bindings. Avoids a converter for the simple cases. -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="12.5"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsActive}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandRailActiveTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="12.5"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsDone}"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource BrandRailDoneTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="12.5"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsUpcoming}"
                                               Foreground="{DynamicResource BrandRailUpcomingTextBrush}" />
                                </Grid>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                </Grid>
            </Panel>
        </Border>

        <!-- ====================================================== -->
        <!-- RIGHT CONTENT PANE                                     -->
        <!-- ====================================================== -->
        <Grid Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}">

            <!-- Page container; each page is its own Grid bound to its
                 ShowXxx flag. Padding matches the handoff's 40 px. -->
            <Grid Margin="40">

                <!-- ===================== 0. SIGN IN ===================== -->
                <!-- New first page added for Phase 4 — License gate. The
                     "Welcome wizard rewrite" memory still applies; for now
                     this gets the OAuth round-trip wired through with the
                     bare minimum visual scaffolding. -->
                <Grid x:Name="PageSignIn"
                      IsVisible="{Binding ShowSignIn}"
                      RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="64" Height="64"
                            CornerRadius="17"
                            Background="{DynamicResource BrandBlackTileBrush}"
                            HorizontalAlignment="Left" Margin="0,4,0,16"
                            BoxShadow="0 8 30 0 #40000000">
                        <Image Source="avares://BoltMate/Assets/BoltMate_logo.png"
                               Width="40" Height="40"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Sign in to continue"
                               FontSize="26" FontWeight="SemiBold"
                               LetterSpacing="-0.4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="340" HorizontalAlignment="Left"
                               Text="BoltMate uses your account to issue a license and remember your trust ring across machines. Sign in once per machine; we'll open a browser to complete OAuth."
                               FontSize="14.5" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <TextBlock Grid.Row="3"
                               Text="{Binding SignInStatus}"
                               IsVisible="{Binding SignInStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="12"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,18,0,0" />

                    <StackPanel Grid.Row="5" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8"
                                Margin="0,18,0,0"
                                VerticalAlignment="Bottom">
                        <Button Content="Sign in"
                                Classes="primary"
                                Command="{Binding SignInCommand}"
                                IsEnabled="{Binding !SignInBusy}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1a. WELCOME ===================== -->
                <!-- All hero content packs to the top; the * row pushes the
                     trailing footer button to the bottom-right of the pane. -->
                <Grid x:Name="PageWelcome"
                      IsVisible="{Binding ShowWelcome}"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

                    <!-- 64 px black app tile w/ bolt mark -->
                    <Border Grid.Row="0"
                            Width="64" Height="64"
                            CornerRadius="17"
                            Background="{DynamicResource BrandBlackTileBrush}"
                            HorizontalAlignment="Left" Margin="0,4,0,16"
                            BoxShadow="0 8 30 0 #40000000">
                        <Image Source="avares://BoltMate/Assets/BoltMate_logo.png"
                               Width="40" Height="40"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Welcome to BoltMate"
                               FontSize="26" FontWeight="SemiBold"
                               LetterSpacing="-0.4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="340" HorizontalAlignment="Left"
                               Text="Your keyboard and mouse will move between your computers together — tap Easy-Switch on either one, and the other follows. Setup takes about a minute."
                               FontSize="14.5" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,18,0,0" ColumnSpacing="6">
                        <ui:FASymbolIcon Grid.Column="0" Symbol="Important" FontSize="13"
                                         Foreground="{DynamicResource TextTertiaryBrush}"
                                         VerticalAlignment="Top" Margin="0,2,0,0" />
                        <TextBlock Grid.Column="1"
                                   Text="Works with Easy-Switch Logitech devices set up in Logi Options+."
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <CheckBox Grid.Row="4"
                              Content="Launch BoltMate on startup"
                              IsChecked="{Binding AutostartChecked, Mode=TwoWay}"
                              Margin="0,18,0,0" />

                    <StackPanel Grid.Row="6" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8"
                                Margin="0,18,0,0"
                                VerticalAlignment="Bottom">
                        <Button Content="Get started"
                                Classes="primary"
                                Command="{Binding GetStartedCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1b. NETWORK PRIMER ===================== -->
                <Grid x:Name="PageNetworkPrimer"
                      IsVisible="{Binding ShowNetworkPrimer}"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="56" Height="56" CornerRadius="15"
                            HorizontalAlignment="Left"
                            Background="#2999FF55"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Globe" FontSize="28"
                                         Foreground="{DynamicResource AccentForegroundBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               x:Name="NetworkPrimerHeading"
                               Text="Let your computers find each other"
                               FontSize="23" FontWeight="SemiBold"
                               LetterSpacing="-0.35"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               x:Name="NetworkPrimerBody"
                               MaxWidth="366" HorizontalAlignment="Left"
                               Text="BoltMate sends tiny heartbeats across your local network so your peripherals know which machine you've moved to. Nothing leaves your network — no traffic ever crosses the internet."
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Not now"
                                Command="{Binding NetworkPrimerNotNowCommand}" />
                        <Button Content="Grant access"
                                Classes="primary"
                                IsEnabled="{Binding NetworkPrimerGrantEnabled}"
                                Command="{Binding NetworkPrimerGrantCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1c. NETWORK REFUSAL ==================== -->
                <Grid x:Name="PageNetworkRefusal"
                      IsVisible="{Binding ShowNetworkRefusal}"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="56" Height="56" CornerRadius="15"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource CautionTintBrush}"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Important" FontSize="28"
                                         Foreground="{DynamicResource CautionBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="BoltMate needs Local Network access"
                               FontSize="23" FontWeight="SemiBold"
                               LetterSpacing="-0.35"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="420"
                               Text="Without local network access there&apos;s no way to tell your other computers you&apos;ve switched — you&apos;d be back to pressing Easy-Switch on every device by hand. You can grant it now, or quit and set it up later."
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Quit BoltMate"
                                Command="{Binding QuitCommand}" />
                        <Button Content="Grant access"
                                Classes="primary"
                                IsEnabled="{Binding NetworkRefusalGrantEnabled}"
                                Command="{Binding NetworkRefusalGrantCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1d. HID PRIMER ========================= -->
                <Grid x:Name="PageInputMonitoringPrimer"
                      IsVisible="{Binding ShowInputMonitoringPrimer}"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="56" Height="56" CornerRadius="15"
                            HorizontalAlignment="Left"
                            Background="#2999FF55"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Keyboard" FontSize="28"
                                         Foreground="{DynamicResource AccentForegroundBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Read switch events from your receiver"
                               FontSize="23" FontWeight="SemiBold"
                               LetterSpacing="-0.35"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="366"
                               Text="macOS calls this Input Monitoring because it gates all USB device access. BoltMate uses it only to notice when you press Easy-Switch on the Bolt receiver. It never logs keystrokes or any other input."
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Not now"
                                Command="{Binding InputMonitoringPrimerNotNowCommand}" />
                        <Button Content="Grant access"
                                Classes="primary"
                                IsEnabled="{Binding InputMonitoringPrimerGrantEnabled}"
                                Command="{Binding InputMonitoringPrimerGrantCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1e. HID REFUSAL ======================== -->
                <Grid x:Name="PageInputMonitoringRefusal"
                      IsVisible="{Binding ShowInputMonitoringRefusal}"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="56" Height="56" CornerRadius="15"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource CautionTintBrush}"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Important" FontSize="28"
                                         Foreground="{DynamicResource CautionBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="BoltMate needs Input Monitoring"
                               FontSize="23" FontWeight="SemiBold"
                               LetterSpacing="-0.35"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="420"
                               Text="Without HID access BoltMate can&apos;t see Easy-Switch presses at all, so there&apos;s no way to move your devices between computers together. Grant Input Monitoring in System Settings, or quit and come back later."
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Quit BoltMate"
                                Command="{Binding QuitCommand}" />
                        <Button Content="Open System Settings"
                                Classes="primary"
                                IsEnabled="{Binding InputMonitoringRefusalGrantEnabled}"
                                Command="{Binding InputMonitoringRefusalGrantCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1f. NOTIFICATIONS PRIMER =============== -->
                <Grid x:Name="PageNotificationsPrimer"
                      IsVisible="{Binding ShowNotificationsPrimer}"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="44" Height="44" CornerRadius="12"
                            HorizontalAlignment="Left"
                            Background="#2999FF55"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Comment" FontSize="22"
                                         Foreground="{DynamicResource AccentForegroundBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Notifications keep you in the loop"
                               FontSize="21" FontWeight="SemiBold"
                               LetterSpacing="-0.35"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               Text="BoltMate stays quiet until something actually needs you. When it speaks up, here&apos;s what you can expect:"
                               FontSize="13.5" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <!-- What-to-expect list -->
                    <StackPanel Grid.Row="3" Spacing="10" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="26" Height="26" CornerRadius="7"
                                    Background="{DynamicResource RowBackgroundBrush}"
                                    VerticalAlignment="Top">
                                <ui:FASymbolIcon Symbol="Important" FontSize="14"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="2" MaxWidth="380">
                                <TextBlock Text="Device &amp; connection issues"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="When a paired device drops off or needs reconnecting."
                                           FontSize="12.5" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="26" Height="26" CornerRadius="7"
                                    Background="{DynamicResource RowBackgroundBrush}"
                                    VerticalAlignment="Top">
                                <ui:FASymbolIcon Symbol="Accept" FontSize="14"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="2" MaxWidth="380">
                                <TextBlock Text="Updates"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="When a new version of BoltMate is ready to install."
                                           FontSize="12.5" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="26" Height="26" CornerRadius="7"
                                    Background="{DynamicResource RowBackgroundBrush}"
                                    VerticalAlignment="Top">
                                <ui:FASymbolIcon Symbol="Document" FontSize="14"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Spacing="2" MaxWidth="380">
                                <TextBlock Text="License &amp; trial reminders"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Occasional reminders about your trial or license."
                                           FontSize="12.5" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Status card: top row = "Current status" + pill side-by-side;
                         sub-line wraps underneath. -->
                    <Border Grid.Row="4"
                            BorderBrush="{DynamicResource CardStrokeBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Background="{DynamicResource CardBackgroundBrush}"
                            Padding="14,12" Margin="0,16,0,0">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="Current status"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border CornerRadius="12" Padding="10,4"
                                        VerticalAlignment="Center"
                                        Background="{Binding NotificationsPillBackground}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                 Fill="{Binding NotificationsPillDot}" />
                                        <TextBlock Text="{Binding NotificationsPillText}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding NotificationsPillForeground}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Managed by System Settings — change it there now, or any time under BoltMate › Settings."
                                       FontSize="11.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextTertiaryBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="6" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="10" Margin="0,18,0,0">
                        <Button Content="Open in System Settings ↗"
                                Command="{Binding NotificationsPrimerOpenSettingsCommand}" />
                        <Button Content="Continue"
                                Classes="primary"
                                Command="{Binding NotificationsPrimerContinueCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1g. DONE ============================== -->
                <Grid x:Name="PageDone"
                      IsVisible="{Binding ShowDone}"
                      RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="60" Height="60" CornerRadius="17"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource BrandGreenBrush}"
                            BoxShadow="0 8 30 0 #4099FF55"
                            Margin="0,4,0,16">
                        <Path Data="M 14,30 L 26,42 L 46,18"
                              Stroke="#15240C" StrokeThickness="4"
                              StrokeJoin="Round" StrokeLineCap="Round" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="You&apos;re all set"
                               FontSize="26" FontWeight="SemiBold"
                               LetterSpacing="-0.4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <!-- Description under the title (handoff "what to expect" lead-in). -->
                    <TextBlock Grid.Row="2"
                               Text="BoltMate is running quietly in your menu bar. Here&apos;s what to expect from now on:"
                               FontSize="14" TextWrapping="Wrap" MaxWidth="440"
                               HorizontalAlignment="Left"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <!-- Bulleted "what to expect" list. Each row uses a 2-column
                         Grid so the wrapping TextBlock has a real width to wrap
                         against (a plain StackPanel of Orientation=Horizontal
                         lets the TextBlock claim infinite width and never wrap). -->
                    <StackPanel Grid.Row="3" Spacing="8" Margin="0,16,0,0" MaxWidth="460">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     VerticalAlignment="Top" Margin="0,8,0,0"
                                     Fill="{DynamicResource BrandGreenBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="Tap Easy-Switch on any device and the rest of the desk hops with it."
                                       FontSize="13.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     VerticalAlignment="Top" Margin="0,8,0,0"
                                     Fill="{DynamicResource BrandGreenBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="The bolt in your menu bar turns amber if something needs your attention."
                                       FontSize="13.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     VerticalAlignment="Top" Margin="0,8,0,0"
                                     Fill="{DynamicResource BrandGreenBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="Open Status anytime to see what&apos;s connected and where it is."
                                       FontSize="13.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8"
                                VerticalAlignment="Bottom"
                                Margin="0,18,0,0">
                        <Button Content="Open BoltMate"
                                Classes="primary"
                                Command="{Binding DoneOpenCommand}" />
                    </StackPanel>
                </Grid>

                <!-- ===================== 1h. LINUX FAST-PATH ==================== -->
                <Grid x:Name="PageLinux"
                      IsVisible="{Binding ShowLinux}"
                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <Border Grid.Row="0"
                            Width="56" Height="56" CornerRadius="15"
                            HorizontalAlignment="Left"
                            Background="#2999FF55"
                            Margin="0,4,0,16">
                        <ui:FASymbolIcon Symbol="Globe" FontSize="28"
                                         Foreground="{DynamicResource AccentForegroundBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Linux: best-effort"
                               FontSize="23" FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <TextBlock Grid.Row="2"
                               MaxWidth="420"
                               Text="BoltMate runs on Linux as a best-effort target — there's no Logitech Options+ companion, so cross-machine sync still works but per-device features lean on Solaar."
                               FontSize="14" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Open BoltMate"
                                Classes="primary"
                                Command="{Binding DoneOpenCommand}" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
