<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LogiPlusSwitcher.App.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <!--
        Menu items are populated programmatically by TrayMenuController so they
        can react to the IObservableCache<BoltReceiver, string> + the
        per-receiver IObservableCache<PairedDevice, byte>. The XAML defines
        only the shell + icon + tooltip.
    -->
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon ToolTipText="LogiPlusSwitcher"
                      Icon="avares://LogiPlusSwitcher.App/Assets/tray-icon-light.png">
                <TrayIcon.Menu>
                    <NativeMenu />
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
