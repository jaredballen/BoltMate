---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = "BoltMate — Easy-Switch follow for the whole desk",
  description = "Logi Flow only follows the mouse. BoltMate fans every host-switch out to every paired Logitech Bolt device on every machine — keyboard, mouse, headset together.",
  pathname = Astro.url.pathname,
} = Astro.props;

const navItems = [
  { href: "/#how-it-works", label: "How it works" },
  { href: "/#privacy", label: "Privacy" },
  { href: "/pricing", label: "Pricing" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1c1c1e" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://boltmate.app${pathname}`} />
  <link rel="canonical" href={`https://boltmate.app${pathname}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-nav">
    <div class="container nav-row">
      <a href="/" class="brand" aria-label="BoltMate home">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 135.467 135.467" width="28" height="28" focusable="false">
            <g style="fill-rule:evenodd">
              <path
                d="M58.752 39.705c-14.932-.247-29.882.553-33.542 2.586C17.89 46.358-9.096 91.37-9.234 99.742s25.351 54.25 32.533 58.556c7.181 4.306 59.658 5.172 66.977 1.106 7.32-4.067 34.306-49.08 34.445-57.451.138-8.372-25.352-54.25-32.533-58.556-3.59-2.153-18.504-3.446-33.436-3.692m8.77 8.91a1.85 1.85 0 0 1 1.435.652c.283.342.51.793.506 1-.007.374-.752 4.27-3.335 17.435-.74 3.776-1.86 9.507-2.49 12.735-.63 3.229-1.348 6.868-1.598 8.086s-.42 2.276-.377 2.35l.003.004c.066.077.867.27 1.8.434 2.092.365 16.665 3.133 24.41 4.635 3.19.619 5.852 1.247 6.15 1.451.655.448.98 1.308.776 2.055-.085.312-4.984 6.137-10.885 12.943l-22.654 26.128c-6.558 7.564-12.109 13.932-12.338 14.152-.674.648-1.831.498-2.496-.326-.31-.382-.557-.884-.553-1.114s.465-2.74 1.022-5.578 1.606-8.198 2.332-11.914a4333 4333 0 0 1 3.944-20.048c.31-1.534.504-2.86.445-3.012l-.003-.003v-.003h-.003c-.078-.077-1.19-.328-2.47-.558-2.6-.467-15.113-2.85-23.64-4.503-3.072-.596-5.791-1.2-6.043-1.341-.72-.404-1.053-1.744-.666-2.676.075-.18 3.12-3.773 6.767-7.982C54.691 62.31 65.924 49.4 66.353 49.035c.332-.281.75-.418 1.17-.42z"
                style="fill:#99ff55"
                transform="rotate(-1.145 -744.858 -913.399)scale(.8307)"
              />
              <path
                d="M90.275 159.404c-7.32 4.066-59.796 3.2-66.977-1.105-7.182-4.306-32.67-50.185-32.532-58.557s27.126-53.385 34.446-57.451 59.796-3.2 66.977 1.105c7.181 4.306 32.67 50.185 32.531 58.557-.138 8.372-27.126 53.385-34.445 57.451z"
                style="fill:none;stroke:#99ff55;stroke-width:4.8981"
                transform="matrix(.9753 -.0195 .0195 .9753 9.452 -29.5)"
              />
            </g>
          </svg>
        </span>
        <span class="brand-name">BoltMate</span>
      </a>

      <nav aria-label="Primary">
        <ul class="nav-links">
          {navItems.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="nav-cta">
        <a href="/pricing" class="btn btn-outline">Start free trial</a>
        <a href="/pricing#buy" class="btn btn-dark">Buy</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-row">
      <p class="footer-brand">
        BoltMate · A companion utility for <a href="https://www.logitech.com/" rel="nofollow">Logitech</a> Bolt receivers.
      </p>
      <ul class="footer-links">
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/support">Support</a></li>
      </ul>
      <p class="footer-disclaimer">
        Logitech, Logi, Bolt, and Logi Options+ are trademarks of Logitech Inc.
        BoltMate is an independent project and is not affiliated with, endorsed by,
        or sponsored by Logitech.
      </p>
    </div>
  </footer>
</body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bm-bg) 90%, transparent);
    backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid var(--bm-stroke);
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 28px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--bm-fg);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand:hover { text-decoration: none; }
  .brand-name { font-size: 1.05rem; }
  .nav-links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex; gap: 22px;
  }
  .nav-links a {
    color: var(--bm-fg-secondary);
    font-size: 0.94rem;
  }
  .nav-links a:hover { color: var(--bm-fg); text-decoration: none; }
  .nav-cta { display: flex; gap: 10px; }

  @media (max-width: 760px) {
    .nav-links { display: none; }
  }

  .site-footer {
    background: var(--bm-bg-band);
    border-top: 1px solid var(--bm-stroke);
    padding-block: 48px;
    margin-top: 80px;
  }
  .footer-row {
    display: grid;
    gap: 18px;
  }
  .footer-brand { margin: 0; color: var(--bm-fg-secondary); }
  .footer-links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex; gap: 22px;
    font-size: 0.94rem;
  }
  .footer-links a { color: var(--bm-fg-secondary); }
  .footer-disclaimer {
    font-size: 0.82rem;
    color: var(--bm-fg-tertiary);
    max-width: 720px;
    margin: 0;
  }
</style>
