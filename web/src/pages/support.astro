---
import Base from "../layouts/Base.astro";
---

<Base title="Support — BoltMate" pathname="/support">
  <section class="support-hero">
    <div class="container">
      <p class="eyebrow">SUPPORT</p>
      <h1>Tell us what broke.</h1>
      <p class="lede">
        Anything from "device didn't follow" to "I bought it but the
        download won't run." We read every message — replies come from
        a human, not a queue bot.
      </p>
    </div>
  </section>

  <section class="support-form-section">
    <div class="container support-grid">
      <form id="support-form" novalidate>
        <div class="row">
          <label for="email">Your email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="row">
          <label for="name">Your name <span class="optional">optional</span></label>
          <input id="name" name="name" type="text" autocomplete="name" />
        </div>
        <div class="row">
          <label for="subject">Subject</label>
          <input id="subject" name="subject" type="text" />
        </div>
        <div class="row">
          <label for="message">What's going on?</label>
          <textarea id="message" name="message" rows="6" required></textarea>
          <p class="row-hint">
            Include the OS + machine, what you were doing, and what
            actually happened. If you can grab the BoltMate logs from
            the app's Settings → General → Diagnostics, click "Send logs"
            there — it bundles + uploads them for us.
          </p>
        </div>

        <div class="actions">
          <button type="submit" class="btn btn-primary" id="submit-btn">Send to support</button>
          <p class="status" id="status" role="status" aria-live="polite"></p>
        </div>
      </form>

      <aside class="support-tips">
        <p class="eyebrow">FIRST AID</p>
        <h2>Faster ways to get unstuck</h2>
        <p>
          Most BoltMate issues are HID permissions, firewall rules, or
          one machine on a different LAN segment. Before sending a
          ticket, try:
        </p>
        <ul>
          <li>Check macOS Settings → Privacy &amp; Security → Input Monitoring includes BoltMate.</li>
          <li>Check Windows Defender Firewall allows BoltMate on private networks.</li>
          <li>Confirm all machines are on the same network — VPNs and guest networks usually block multicast.</li>
        </ul>
        <p class="aside-fineprint">
          Reply directly to the email we send you when you submit.
          That's the fastest channel.
        </p>
      </aside>
    </div>
  </section>
</Base>

<script is:inline>
  const form = document.getElementById("support-form");
  const status = document.getElementById("status");
  const submitBtn = document.getElementById("submit-btn");

  if (form && status && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      status.className = "status";

      const data = new FormData(form);
      const email = (data.get("email") || "").toString().trim();
      const message = (data.get("message") || "").toString().trim();
      if (!email || !message) {
        status.textContent = "Email and message are required.";
        status.classList.add("err");
        return;
      }

      const payload = {
        email,
        name: (data.get("name") || "").toString().trim() || undefined,
        subject: (data.get("subject") || "").toString().trim() || "Support request",
        message,
        source: "site",
      };

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const resp = await fetch("/api/support", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (resp.ok || resp.status === 202) {
          form.reset();
          status.textContent = "Got it — we'll reply at " + email + " within a day.";
          status.classList.add("ok");
        } else {
          const body = await resp.text().catch(() => "");
          status.textContent = "Couldn't send: " + (body || resp.statusText);
          status.classList.add("err");
        }
      } catch (err) {
        status.textContent = "Network error — try again in a minute.";
        status.classList.add("err");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send to support";
      }
    });
  }
</script>

<style>
  .support-hero {
    padding: 72px 0 16px;
    text-align: left;
  }
  .support-hero h1 {
    margin: 14px 0 0;
    font-weight: 700;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #161616;
    max-width: 18ch;
  }
  .support-hero .lede {
    margin: 18px 0 0;
    max-width: 56ch;
    font-size: 17px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }

  .support-form-section {
    padding: 48px 0 96px;
  }
  .support-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 36px;
    align-items: start;
  }
  @media (max-width: 880px) {
    .support-grid { grid-template-columns: 1fr; }
  }

  form { display: grid; gap: 18px; }
  .row { display: grid; gap: 6px; }
  .row-hint {
    margin: 6px 0 0;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--bm-fg-tertiary);
  }
  textarea { min-height: 140px; }

  .actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .status {
    margin: 0;
    font-size: 13px;
    color: var(--bm-fg-secondary);
  }
  .status.ok { color: #42701a; }
  .status.err { color: #a93232; }

  .support-tips {
    background: var(--bm-bg-soft);
    border: 1px solid var(--bm-stroke);
    border-radius: 18px;
    padding: 26px 28px;
  }
  .support-tips .eyebrow {
    margin-bottom: 10px;
    color: var(--bm-fg-tertiary);
  }
  .support-tips h2 {
    margin: 0;
    font-weight: 660;
    font-size: 20px;
    color: #161616;
    letter-spacing: -0.015em;
  }
  .support-tips p {
    margin: 12px 0 0;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }
  .support-tips ul {
    list-style: none;
    padding: 0;
    margin: 14px 0;
    display: grid;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.45;
  }
  .support-tips ul li {
    padding-left: 18px;
    position: relative;
    color: var(--bm-fg-secondary);
  }
  .support-tips ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--bm-green-mid);
  }
  .aside-fineprint {
    margin: 0;
    font-size: 12.5px;
    color: var(--bm-fg-tertiary);
  }
</style>
