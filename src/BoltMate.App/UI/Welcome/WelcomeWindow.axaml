<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:BoltMate.App.UI"
        x:Class="BoltMate.App.UI.WelcomeWindow"
        x:DataType="vm:WelcomeViewModel"
        Width="560" Height="460"
        MinWidth="520" MinHeight="440"
        Title="Welcome to BoltMate"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <!--
        First-run welcome + on-demand permission-fix wizard.

        Page layout convention:
          [ heading icon ]
          [ big title ]
          [ paragraph ]
          [ optional status line ]
          [ buttons row pinned to bottom ]

        State machine lives in code-behind. Pages are sibling Grids stacked
        in this Grid; only one is IsVisible=True at a time. The wizard never
        auto-fires an OS prompt — every prompt is tied to an explicit Grant
        button press.

        On first run the user MUST traverse Welcome → (Network) → (HID, Mac
        only) → Done. On subsequent launches the tray "Fix permissions" item
        opens the same flow but skips the Welcome page and starts directly
        at whichever primer is still ungranted.

        Refusal-recovery: any "Not now" or denied-after-Grant press routes
        to a Refusal page for that permission with two buttons: Grant (loops
        back) and Quit BoltMate (full app shutdown). The wizard cannot be
        dismissed by closing the window — Closing handler treats [x] / Cmd-W
        the same as Quit.
    -->
    <Grid Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

        <!-- =========================== WELCOME ============================ -->
        <Grid x:Name="PageWelcome"
              Margin="32"
              IsVisible="{Binding ShowWelcome}"
              RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">
            <Image Grid.Row="0"
                   Source="avares://BoltMate/Assets/app-icon-1024.png"
                   Width="96" Height="96"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
            <TextBlock Grid.Row="1"
                       Text="Welcome to BoltMate"
                       FontSize="24" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate keeps your Logitech Bolt peripherals together as you switch between computers."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="20,12,20,0" />
            <CheckBox Grid.Row="4"
                      Content="Launch BoltMate when I sign in"
                      IsChecked="{Binding AutostartChecked, Mode=TwoWay}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,16" />
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Get started"
                        Classes="accent"
                        Command="{Binding GetStartedCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== NETWORK PRIMER ===================== -->
        <Grid x:Name="PageNetworkPrimer"
              Margin="32"
              IsVisible="{Binding ShowNetworkPrimer}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Globe"
                             FontSize="56"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="BoltMate needs Local Network access"
                       FontSize="22" FontWeight="SemiBold"
                       TextAlignment="Center" TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate sends small heartbeats on your LAN so peripherals follow you between your computers. Nothing leaves your network — no traffic crosses the internet."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding NetworkStatusLine}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="12"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,16,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Not now" Command="{Binding NetworkPrimerNotNowCommand}" />
                <Button Content="Grant"
                        Classes="accent"
                        IsEnabled="{Binding NetworkPrimerGrantEnabled}"
                        Command="{Binding NetworkPrimerGrantCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== NETWORK REFUSAL ==================== -->
        <Grid x:Name="PageNetworkRefusal"
              Margin="32"
              IsVisible="{Binding ShowNetworkRefusal}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Important"
                             FontSize="56"
                             Foreground="{DynamicResource SystemFillColorCautionBrush}"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="Local Network is required"
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate can't sync between your computers without LAN access. Without it, you'd have to manually press Easy-Switch on each device when moving between machines."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding NetworkStatusLine}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="12"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,16,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Quit BoltMate" Command="{Binding QuitCommand}" />
                <Button Content="Grant"
                        Classes="accent"
                        IsEnabled="{Binding NetworkRefusalGrantEnabled}"
                        Command="{Binding NetworkRefusalGrantCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== HID PRIMER (MAC) =================== -->
        <Grid x:Name="PageInputMonitoringPrimer"
              Margin="32"
              IsVisible="{Binding ShowInputMonitoringPrimer}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Keyboard"
                             FontSize="56"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="BoltMate needs HID device access"
                       FontSize="22" FontWeight="SemiBold"
                       TextAlignment="Center" TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="macOS labels this 'Input Monitoring' because it gates all HID device access. BoltMate uses it ONLY to read host-switch events from your Bolt receiver. BoltMate does not log keystrokes or any other input."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding InputMonitoringStatusLine}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="12"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,16,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Not now" Command="{Binding InputMonitoringPrimerNotNowCommand}" />
                <Button Content="Grant"
                        Classes="accent"
                        IsEnabled="{Binding InputMonitoringPrimerGrantEnabled}"
                        Command="{Binding InputMonitoringPrimerGrantCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== HID REFUSAL (MAC) ================== -->
        <Grid x:Name="PageInputMonitoringRefusal"
              Margin="32"
              IsVisible="{Binding ShowInputMonitoringRefusal}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Important"
                             FontSize="56"
                             Foreground="{DynamicResource SystemFillColorCautionBrush}"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="HID device access is required"
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="macOS labels this 'Input Monitoring' because it gates all HID device access. BoltMate uses it ONLY to read host-switch events from your Bolt receiver. BoltMate does not log keystrokes or any other input. Without this permission BoltMate can't talk to your Bolt receiver at all."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding InputMonitoringStatusLine}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="12"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,16,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Quit BoltMate" Command="{Binding QuitCommand}" />
                <Button Content="Grant"
                        Classes="accent"
                        IsEnabled="{Binding InputMonitoringRefusalGrantEnabled}"
                        Command="{Binding InputMonitoringRefusalGrantCommand}" />
            </StackPanel>
        </Grid>

        <!-- ====================== NOTIFICATIONS PRIMER ==================== -->
        <Grid x:Name="PageNotificationsPrimer"
              Margin="32"
              IsVisible="{Binding ShowNotificationsPrimer}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Comment"
                             FontSize="56"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="Allow BoltMate to send notifications"
                       FontSize="22" FontWeight="SemiBold"
                       TextAlignment="Center" TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate uses OS notifications to surface alerts when something needs your attention — a permission gets revoked, the LAN drops, or no Bolt receiver is connected. Notifications are optional; BoltMate works fine without them. Tap Allow to bring up the OS prompt."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding NotificationsStatusLine}"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="12"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,16,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Not now"
                        Command="{Binding NotificationsPrimerNotNowCommand}" />
                <Button Content="Allow"
                        Classes="accent"
                        IsEnabled="{Binding NotificationsPrimerGrantEnabled}"
                        Command="{Binding NotificationsPrimerAllowCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== DONE =============================== -->
        <Grid x:Name="PageDone"
              Margin="32"
              IsVisible="{Binding ShowDone}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <ui:FASymbolIcon Grid.Row="0"
                             Symbol="Accept"
                             FontSize="64"
                             Foreground="LimeGreen"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,16" />
            <TextBlock Grid.Row="1"
                       Text="You're all set."
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate is now active in your menu bar."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Open BoltMate"
                        Classes="accent"
                        Command="{Binding DoneOpenCommand}" />
            </StackPanel>
        </Grid>

        <!-- =========================== LINUX FAST-PATH ==================== -->
        <Grid x:Name="PageLinux"
              Margin="32"
              IsVisible="{Binding ShowLinux}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">
            <Image Grid.Row="0"
                   Source="avares://BoltMate/Assets/app-icon-1024.png"
                   Width="96" Height="96"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
            <TextBlock Grid.Row="1"
                       Text="Nothing to do — opening BoltMate"
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="2"
                       Text="BoltMate doesn't need any permission prompts on Linux."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="10,12,10,0" />
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Open BoltMate"
                        Classes="accent"
                        Command="{Binding DoneOpenCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
