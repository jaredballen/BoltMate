<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="using:LogiPlusSwitcher.App"
        x:Class="LogiPlusSwitcher.App.SettingsWindow"
        Width="720" Height="520"
        MinWidth="640" MinHeight="440"
        Title="LogiPlusSwitcher Settings"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
        </Style>
    </Window.Styles>

    <TabControl x:Name="MainTabs" TabStripPlacement="Left" Margin="0">

        <!-- Status tab -->
        <TabItem Header="Status" x:Name="StatusTab">
            <Grid Margin="16" RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                    <TextBlock Text="Status" FontSize="20" FontWeight="Bold" />
                    <TextBlock Foreground="#999" FontSize="12" TextWrapping="Wrap">
                        Online devices on this machine, the local network access state, and any peers reachable on the LAN.
                    </TextBlock>
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="16">

                        <!-- Section 1: This machine -->
                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="This machine" FontSize="14" FontWeight="Bold" />
                                <ItemsControl x:Name="LocalDevicesList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="app:SettingsWindow+LocalDeviceRow">
                                            <Border Padding="8" Margin="0,0,0,4" Background="#10FFFFFF" CornerRadius="4">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                    <TextBlock Text="{Binding SubLine}" Foreground="#AAA" FontSize="11"
                                                               FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="LocalEmptyLine"
                                           Text="No devices currently linked up."
                                           Foreground="#888" FontSize="12" IsVisible="False" />
                            </StackPanel>
                        </Border>

                        <!-- Section 2: Network access permission -->
                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Network access" FontSize="14" FontWeight="Bold" />
                                <TextBlock x:Name="NetworkPermissionLine"
                                           Foreground="#CCC" FontSize="12" />
                                <Button x:Name="OpenNetworkSettingsButton"
                                        Content="Open Privacy Settings"
                                        Click="OnOpenNetworkSettings"
                                        IsVisible="False" />
                            </StackPanel>
                        </Border>

                        <!-- Section 3: Peers -->
                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Peers" FontSize="14" FontWeight="Bold" />
                                <TextBlock x:Name="PeersStateLine"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap" />
                                <ItemsControl x:Name="PeersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="app:SettingsWindow+PeerRow">
                                            <Border Padding="8" Margin="0,0,0,4" Background="#10FFFFFF" CornerRadius="4">
                                                <StackPanel Spacing="3">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Grid.Column="1" Text="{Binding LastSeen}" Foreground="#999" FontSize="11" VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding MetaLine}" Foreground="#999" FontSize="11"
                                                               FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                    <ItemsControl ItemsSource="{Binding Devices}" Margin="6,2,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="app:SettingsWindow+PeerDeviceRow">
                                                                <TextBlock Text="{Binding Line}" Foreground="#AAA" FontSize="11"
                                                                           FontFamily="JetBrains Mono,Menlo,Consolas,monospace" Margin="0,1" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="PeersOverflowLine"
                                           Foreground="#888" FontSize="11" IsVisible="False" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <!-- About tab -->
        <TabItem Header="About" x:Name="AboutTab">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LogiPlusSwitcher" FontSize="20" FontWeight="Bold" />
                        <TextBlock x:Name="AboutVersionLine" Foreground="#999" FontSize="12" />
                    </StackPanel>

                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Updates" FontSize="14" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Last checked:" Foreground="#999" VerticalAlignment="Center" />
                                <TextBlock x:Name="LastCheckedLine" Text="never" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="CheckNowButton" Content="Check for updates" Click="OnCheckForUpdatesNow" />
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatusLine"
                                       Foreground="#CCC" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Startup" FontSize="14" FontWeight="Bold" />
                            <CheckBox x:Name="LaunchAtLoginToggle"
                                      Content="Launch LogiPlusSwitcher at login"
                                      IsCheckedChanged="OnLaunchAtLoginChanged" />
                            <TextBlock x:Name="LaunchAtLoginDetail"
                                       Margin="22,0,0,0" Foreground="#999" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Privacy" FontSize="14" FontWeight="Bold" />
                            <CheckBox x:Name="TelemetryToggle"
                                      Content="Send anonymous diagnostics"
                                      IsCheckedChanged="OnTelemetryChanged" />
                            <TextBlock Margin="22,0,0,0" Foreground="#999" FontSize="12" TextWrapping="Wrap">
                                Off by default. When on, error reports and de-identified usage counts go to Azure App Insights.
                                No device serials, key strokes, or file paths are ever sent.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Diagnostics" FontSize="14" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Open logs folder" Click="OnOpenLogsFolder" />
                            </StackPanel>
                            <TextBlock x:Name="LogsPathLine" Foreground="#999" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- License tab -->
        <TabItem Header="License" x:Name="LicenseTab">
            <StackPanel Margin="16" Spacing="16">
                <TextBlock Text="License" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Licensing — coming soon" Foreground="#CCC" FontSize="13" />
                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Activation key" FontSize="14" FontWeight="Bold" />
                        <TextBox IsEnabled="False" Text="" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Activate" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock Foreground="#999" FontSize="12" TextWrapping="Wrap">
                            Licensing is not yet available. The current build runs all features without an activation key.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </TabItem>

    </TabControl>
</Window>
