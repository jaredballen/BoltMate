<Project>

  <!--
    Stage libhidapi next to every project's output (and publish) assemblies so
    .NET's default DllImport search (AssemblyDirectory) finds it without
    DYLD_*_PATH hacks. Two responsibilities:
      - macOS dev: copy /opt/homebrew/lib/libhidapi.dylib (Apple Silicon) or
        /usr/local/lib/libhidapi.dylib (Intel) — install via `brew install hidapi`.
      - macOS publish: same dylib bundled into the publish output so the
        artifact is self-contained.
      - Windows: search common install locations for hidapi.dll. For builds in
        CI we'll pull this from a NuGet (hidapi-VC) or vcpkg in a follow-up.
  -->

  <!-- macOS: resolved at project-evaluation time (parity with the Windows
       block below). The earlier AfterTargets="Build" approach broke whenever
       MSBuild reused properties across re-entrant target invocations. -->
  <PropertyGroup Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'">
    <_BrewArmHidApi>/opt/homebrew/lib/libhidapi.dylib</_BrewArmHidApi>
    <_BrewIntelHidApi>/usr/local/lib/libhidapi.dylib</_BrewIntelHidApi>
    <ResolvedHidApiMacSource Condition="Exists('$(_BrewArmHidApi)')">$(_BrewArmHidApi)</ResolvedHidApiMacSource>
    <ResolvedHidApiMacSource Condition="'$(ResolvedHidApiMacSource)' == '' AND Exists('$(_BrewIntelHidApi)')">$(_BrewIntelHidApi)</ResolvedHidApiMacSource>
  </PropertyGroup>
  <ItemGroup Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true' AND '$(ResolvedHidApiMacSource)' != ''">
    <Content Include="$(ResolvedHidApiMacSource)">
      <Link>libhidapi.dylib</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>
  <Target Name="_WarnIfMissingMacHidApi"
          BeforeTargets="Build"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true' AND '$(ResolvedHidApiMacSource)' == ''">
    <Warning Text="libhidapi.dylib not found at standard Homebrew paths. Run 'brew install hidapi'." />
  </Target>

  <!--
    Windows hidapi.dll staging. Resolved eagerly at project-evaluation time
    (top-level PropertyGroup + ItemGroup) so the standard SDK copy logic
    stages it to both OutputPath AND PublishDir. Earlier in-target approaches
    silently dropped on Publish because the AfterTargets/BeforeTargets hooks
    didn't intersect with the publish target graph.
  -->
  <PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
    <_WindowsSysHidApi>$(WINDIR)\System32\hidapi.dll</_WindowsSysHidApi>
    <_VcpkgHidApi>C:\vcpkg\installed\x64-windows\bin\hidapi.dll</_VcpkgHidApi>
    <_DevHidApi>C:\dev\hidapi-win\x64\hidapi.dll</_DevHidApi>
    <ResolvedHidApiWindowsSource Condition="'$(HidApiWindowsPath)' != '' AND Exists('$(HidApiWindowsPath)')">$(HidApiWindowsPath)</ResolvedHidApiWindowsSource>
    <ResolvedHidApiWindowsSource Condition="'$(ResolvedHidApiWindowsSource)' == '' AND Exists('$(_DevHidApi)')">$(_DevHidApi)</ResolvedHidApiWindowsSource>
    <ResolvedHidApiWindowsSource Condition="'$(ResolvedHidApiWindowsSource)' == '' AND Exists('$(_VcpkgHidApi)')">$(_VcpkgHidApi)</ResolvedHidApiWindowsSource>
    <ResolvedHidApiWindowsSource Condition="'$(ResolvedHidApiWindowsSource)' == '' AND Exists('$(_WindowsSysHidApi)')">$(_WindowsSysHidApi)</ResolvedHidApiWindowsSource>
  </PropertyGroup>
  <ItemGroup Condition="'$(OS)' == 'Windows_NT' AND '$(ResolvedHidApiWindowsSource)' != ''">
    <Content Include="$(ResolvedHidApiWindowsSource)">
      <Link>hidapi.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>
  <Target Name="_WarnIfMissingWindowsHidApi"
          BeforeTargets="Build"
          Condition="'$(OS)' == 'Windows_NT' AND '$(ResolvedHidApiWindowsSource)' == ''">
    <Warning Text="hidapi.dll not found. Install via vcpkg (vcpkg install hidapi), extract from a libusb/hidapi GitHub release into C:\dev\hidapi-win\x64\, or set HidApiWindowsPath in Directory.Build.props." />
  </Target>

  <!--
    macOS .app bundle build: when publishing BoltMate.App for osx-*,
    wrap the publish output in a proper .app directory with Info.plist so the
    binary behaves as a real Mac menubar app (LSUIElement) and can be code-
    signed / notarized.
  -->
  <Target Name="StageMacAppBundle"
          AfterTargets="Publish"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'
                     AND ('$(RuntimeIdentifier)' == 'osx-arm64' OR '$(RuntimeIdentifier)' == 'osx-x64')
                     AND '$(AssemblyName)' == 'BoltMate'">
    <PropertyGroup>
      <!-- Use a subdir so we don't collide with the build-output executable
           name BoltMate, which on a case-insensitive volume could clash
           with the BoltMate.app bundle name. -->
      <_AppBundlePath>$([System.IO.Path]::GetFullPath('$(PublishDir)../app-bundle/BoltMate.app'))</_AppBundlePath>
      <_AppContents>$(_AppBundlePath)/Contents</_AppContents>
      <_AppMacOS>$(_AppContents)/MacOS</_AppMacOS>
      <_AppResources>$(_AppContents)/Resources</_AppResources>
    </PropertyGroup>

    <RemoveDir Directories="$(_AppBundlePath)" Condition="Exists('$(_AppBundlePath)')" />
    <Exec Command="mkdir -p &quot;$(_AppMacOS)&quot; &quot;$(_AppResources)&quot;" />

    <ItemGroup>
      <!-- Use forward-slash wildcards: MSBuild's globber treats backslash as
           a literal character on Unix, so '**\*' silently matches nothing on
           Mac and the bundle ends up empty. Same for Exclude. -->
      <_PublishedFiles Include="$(PublishDir)**/*" Exclude="$(PublishDir)Assets/**/*;$(PublishDir)*.icns" />
      <_IconFile Include="$(PublishDir)Assets/app-icon.icns" />
      <_IconFile Include="$(PublishDir)app-icon.icns" />
    </ItemGroup>
    <!-- Preserve subdirectory structure under MacOS/ via RecursiveDir. A
         plain DestinationFolder flattens everything which loses any nested
         runtimes/ or native subdirs the publish step may stage. -->
    <Copy SourceFiles="@(_PublishedFiles)"
          DestinationFiles="@(_PublishedFiles->'$(_AppMacOS)/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_IconFile)" DestinationFolder="$(_AppResources)" SkipUnchangedFiles="true" Condition="Exists('%(_IconFile.Identity)')" />

    <Message Importance="high" Text="StageMacAppBundle: copied @(_PublishedFiles->Count()) file(s) into $(_AppMacOS)" />

    <WriteLinesToFile
        File="$(_AppContents)/Info.plist"
        Overwrite="true"
        Lines="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;;&lt;!DOCTYPE plist PUBLIC &quot;-//Apple//DTD PLIST 1.0//EN&quot; &quot;http://www.apple.com/DTD/PropertyList-1.0.dtd&quot;&gt;;&lt;plist version=&quot;1.0&quot;&gt;;&lt;dict&gt;;  &lt;key&gt;CFBundleIdentifier&lt;/key&gt;;  &lt;string&gt;com.jaredballen.BoltMate&lt;/string&gt;;  &lt;key&gt;CFBundleName&lt;/key&gt;;  &lt;string&gt;BoltMate&lt;/string&gt;;  &lt;key&gt;CFBundleDisplayName&lt;/key&gt;;  &lt;string&gt;BoltMate&lt;/string&gt;;  &lt;key&gt;CFBundleExecutable&lt;/key&gt;;  &lt;string&gt;BoltMate&lt;/string&gt;;  &lt;key&gt;CFBundleIconFile&lt;/key&gt;;  &lt;string&gt;app-icon.icns&lt;/string&gt;;  &lt;key&gt;CFBundleVersion&lt;/key&gt;;  &lt;string&gt;$(Version)&lt;/string&gt;;  &lt;key&gt;CFBundleShortVersionString&lt;/key&gt;;  &lt;string&gt;$(Version)&lt;/string&gt;;  &lt;key&gt;CFBundlePackageType&lt;/key&gt;;  &lt;string&gt;APPL&lt;/string&gt;;  &lt;key&gt;LSMinimumSystemVersion&lt;/key&gt;;  &lt;string&gt;11.0&lt;/string&gt;;  &lt;key&gt;LSUIElement&lt;/key&gt;;  &lt;true/&gt;;  &lt;key&gt;NSUserNotificationAlertStyle&lt;/key&gt;;  &lt;string&gt;alert&lt;/string&gt;;  &lt;key&gt;NSHumanReadableCopyright&lt;/key&gt;;  &lt;string&gt;Copyright (c) Jared Ballen&lt;/string&gt;;  &lt;key&gt;NSHighResolutionCapable&lt;/key&gt;;  &lt;true/&gt;;&lt;/dict&gt;;&lt;/plist&gt;" />

    <Exec Command="chmod +x &quot;$(_AppMacOS)/BoltMate&quot;" IgnoreExitCode="true" />

    <!--
      Compile the Objective-C UNUserNotificationCenter sidecar into a
      tiny dylib alongside the main binary. Lets the .NET host call into
      the modern notifications API via plain DllImports — blocks stay
      entirely on the Objective-C side rather than crossing the managed
      boundary, which is the only reliable way to talk to libdispatch-
      backed completion-handler APIs from C#. The dylib is placed in
      Contents/MacOS so the default dlopen search picks it up next to
      the executable; this step runs BEFORE the codesign step below so
      the dylib gets sealed into the bundle's signature.
    -->
    <Exec Command="clang -arch arm64 -fobjc-arc -dynamiclib -framework Foundation -framework UserNotifications -o &quot;$(_AppMacOS)/libboltmate_un.dylib&quot; &quot;$(MSBuildThisFileDirectory)BoltMate.App/Native/Mac/boltmate_un.m&quot;"
          IgnoreExitCode="false" />

    <!--
      Re-sign the bundle ad-hoc with our CFBundleIdentifier so the signing
      identity matches the Info.plist. Without this step the .NET apphost
      stub ships with Identifier=apphost + Info.plist=not bound, which
      makes macOS treat the bundle as an unverified identity. The user-
      facing symptom is that UNUserNotificationCenter / NSUserNotification
      can't register the app properly in System Settings; even after the
      user toggles Allow Notifications, banners are suppressed (the OS
      routes them to Notification Center in deliver-silently mode).
      Re-signing with the proper identifier binds the plist into the seal
      and gives the bundle a stable identity the OS recognises.

      The deep flag re-signs every nested binary (.NET framework dylibs)
      so nothing in the bundle carries a stale signature that would fail
      Gatekeeper inspection. The dash signing identity is ad-hoc: free,
      works on the dev machine and for sideloaded installs, but won't
      bypass Gatekeeper on other Macs. When the Apple Developer Program
      enrolment lands, swap the dash for a "Developer ID Application:..."
      identity (and follow with notarisation + stapling); the rest of
      this command is unchanged.
    -->
    <Exec Command="codesign -f --deep -s - -i com.jaredballen.BoltMate &quot;$(_AppBundlePath)&quot;"
          IgnoreExitCode="true" />

    <Message Importance="high" Text="Built macOS app bundle: $(_AppBundlePath)" />
  </Target>


</Project>
