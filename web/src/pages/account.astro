---
import Base from "../layouts/Base.astro";
import { loadPricing } from "../lib/pricing.ts";

const pricing = await loadPricing();
---

<Base title="Your account — BoltMate" pathname="/account">
  <section class="account-section">
    <div class="container">

      <!-- ===== Loading ===== -->
      <div id="account-loading" class="state-card">
        <p class="eyebrow">ONE MOMENT</p>
        <h1>Loading your license…</h1>
      </div>

      <!-- ===== Signed-out ===== -->
      <div id="account-unauth" class="state-card" hidden>
        <p class="eyebrow">SIGNED OUT</p>
        <h1>Sign in to see your license.</h1>
        <p class="state-lede">Use the same account you bought BoltMate with — or the one you'd like to start a trial under.</p>
        <a href="/.auth/login/aad?post_login_redirect_uri=/account" class="btn btn-primary-lg">Sign in</a>
      </div>

      <!-- ===== Error ===== -->
      <div id="account-error" class="state-card error" hidden>
        <p class="eyebrow">HMM</p>
        <h1>Couldn't load your license.</h1>
        <p id="account-error-msg" class="state-lede"></p>
        <a href="/support" class="btn btn-secondary-lg">Contact support</a>
      </div>

      <!-- ===== OK ===== -->
      <div id="account-ok" hidden>
        <header class="account-header">
          <p class="eyebrow"><span id="tier-eyebrow">TRIAL</span></p>
          <h1 id="greeting">Your BoltMate license</h1>
          <p id="status-line" class="state-lede"></p>
        </header>

        <!-- Trial-expired banner (entry from desktop app on a dead trial) -->
        <div id="trial-banner" class="trial-banner" hidden>
          <div>
            <div class="banner-title">Your trial ended</div>
            <p class="banner-body">Pick up the lifetime license to keep BoltMate running on every machine you sign into.</p>
          </div>
          <a href="/checkout" class="btn btn-green">Buy lifetime — {pricing.amount}</a>
        </div>

        <div class="cards-grid">
          <!-- License card -->
          <article class="card license-card">
            <div class="card-head">
              <div>
                <p class="card-eyebrow">LICENSE</p>
                <div class="card-title-row">
                  <h2 id="card-tier-name">Trial</h2>
                  <span id="card-status-badge" class="status-badge status-badge-trial">14 DAYS LEFT</span>
                </div>
              </div>
            </div>
            <dl class="license-fields">
              <dt>Sign-in</dt>
              <dd id="license-provider">—</dd>
              <dt>Email</dt>
              <dd id="license-email">—</dd>
              <dt>Issued</dt>
              <dd id="license-issued">—</dd>
              <dt id="expires-label">Expires</dt>
              <dd id="license-expires">—</dd>
            </dl>
            <p class="license-note">
              No license keys to copy. Sign into the BoltMate desktop app
              with the same provider to activate this machine.
            </p>
          </article>

          <!-- Downloads card -->
          <article class="card downloads-card">
            <p class="card-eyebrow">DOWNLOADS</p>
            <h2>Get BoltMate</h2>
            <p class="downloads-lede">Install on every machine you use — your license activates automatically.</p>
            <div class="download-rows">
              <a href="https://github.com/jaredballen/BoltMate/releases/latest" class="download-row">
                <div class="download-icon">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#1d1d1f" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2" />
                    <path d="M12 2v12m0 0l-4-4m4 4l4-4" />
                  </svg>
                </div>
                <div class="download-meta">
                  <div class="download-name">Download for macOS</div>
                  <div class="download-sub">Apple Silicon &amp; Intel · .dmg</div>
                </div>
                <span class="download-cta">↓</span>
              </a>
              <a href="https://github.com/jaredballen/BoltMate/releases/latest" class="download-row">
                <div class="download-icon">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#1d1d1f" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="8" height="8" />
                    <rect x="13" y="3" width="8" height="8" />
                    <rect x="3" y="13" width="8" height="8" />
                    <rect x="13" y="13" width="8" height="8" />
                  </svg>
                </div>
                <div class="download-meta">
                  <div class="download-name">Download for Windows</div>
                  <div class="download-sub">Windows 11 / 10 · .msi</div>
                </div>
                <span class="download-cta">↓</span>
              </a>
            </div>
            <p class="downloads-version" id="downloads-version">Loading version…</p>
          </article>
        </div>

        <!-- Sign-out + danger zone -->
        <div class="account-footer">
          <p class="signout-row">
            Wrong account?
            <a href="/.auth/logout?post_logout_redirect_uri=/" class="text-link">Sign out</a>
          </p>

          <section class="danger-zone">
            <h2>Delete your account</h2>
            <p>
              Removes your BoltMate license and every record we hold against
              this email. Any peer machines signed in with this account stop
              syncing the next time they refresh. This cannot be undone.
            </p>
            <button type="button" id="delete-account-btn" class="btn btn-danger">Delete account</button>
            <p id="delete-status" class="delete-status" role="status" aria-live="polite"></p>
          </section>
        </div>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  function jwtPayload(jwt) {
    try {
      const seg = jwt.split(".")[1];
      const pad = "=".repeat((4 - (seg.length % 4)) % 4);
      const json = atob(seg.replace(/-/g, "+").replace(/_/g, "/") + pad);
      return JSON.parse(json);
    } catch (e) { return null; }
  }

  function fmtDate(iso) {
    if (!iso) return "—";
    const d = new Date(iso);
    if (isNaN(d.getTime())) return "—";
    return d.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function show(id) {
    ["account-loading", "account-unauth", "account-error", "account-ok"].forEach((k) => {
      const el = document.getElementById(k);
      if (el) el.hidden = (k !== id);
    });
  }

  function showError(msg) {
    document.getElementById("account-error-msg").textContent = msg;
    show("account-error");
  }

  async function run() {
    let me;
    try {
      const r = await fetch("/.auth/me");
      me = await r.json();
    } catch (e) {
      show("account-unauth");
      return;
    }

    const principal = me?.clientPrincipal;
    if (!principal) {
      show("account-unauth");
      return;
    }

    const email =
      principal.userDetails ||
      principal.claims?.find?.((c) => c.typ === "email" || c.typ?.endsWith("/emailaddress"))?.val ||
      "(unknown)";
    const provider = principal.identityProvider || "Microsoft";
    document.getElementById("license-email").textContent = email;
    document.getElementById("license-provider").textContent = provider.charAt(0).toUpperCase() + provider.slice(1);
    document.getElementById("greeting").textContent = "Welcome back, " + email;

    const idToken = principal.accessToken || (me && me.id_token);
    if (!idToken) {
      showError("Missing identity token — try signing out and back in.");
      return;
    }

    let resp;
    try {
      resp = await fetch("/api/entitlement", {
        method: "POST",
        headers: { "content-type": "application/json", authorization: "Bearer " + idToken },
        body: JSON.stringify({}),
      });
    } catch (e) {
      showError("Network error — try again in a minute.");
      return;
    }

    if (resp.status === 401) { show("account-unauth"); return; }
    if (resp.status === 403) {
      showError("Your license was revoked. Email support@boltmate.app if this is unexpected.");
      return;
    }
    if (!resp.ok) {
      showError("Couldn't load entitlement (status " + resp.status + ").");
      return;
    }

    const body = await resp.json();
    const payload = jwtPayload(body.jwt) || {};
    const tier = payload.tier || "Trial";
    const iat = payload.iat ? new Date(payload.iat * 1000).toISOString() : null;
    const exp = payload.exp ? new Date(payload.exp * 1000) : null;
    const now = new Date();

    document.getElementById("license-issued").textContent = fmtDate(iat);

    const tierEyebrow = document.getElementById("tier-eyebrow");
    const tierName = document.getElementById("card-tier-name");
    const statusBadge = document.getElementById("card-status-badge");

    if (tier === "Boltmate") {
      tierEyebrow.textContent = "LIFETIME";
      tierName.textContent = "Lifetime";
      statusBadge.textContent = "ACTIVE";
      statusBadge.className = "status-badge status-badge-active";
      document.getElementById("expires-label").textContent = "Status";
      document.getElementById("license-expires").textContent = "Licensed for life";
      document.getElementById("status-line").textContent = "Lifetime license — active on every machine you sign into.";
    } else {
      tierEyebrow.textContent = "TRIAL";
      tierName.textContent = "Trial";
      document.getElementById("expires-label").textContent = "Expires";
      document.getElementById("license-expires").textContent = exp ? fmtDate(exp.toISOString()) : "—";
      if (exp && exp.getTime() <= now.getTime()) {
        document.getElementById("trial-banner").hidden = false;
        document.getElementById("status-line").textContent = "Your trial has expired.";
        statusBadge.textContent = "EXPIRED";
        statusBadge.className = "status-badge status-badge-expired";
      } else if (exp) {
        const daysLeft = Math.max(0, Math.ceil((exp.getTime() - now.getTime()) / 86400000));
        document.getElementById("status-line").textContent =
          daysLeft === 1 ? "1 day left in your trial." : daysLeft + " days left in your trial.";
        statusBadge.textContent = (daysLeft === 1 ? "1 DAY LEFT" : daysLeft + " DAYS LEFT");
        statusBadge.className = "status-badge status-badge-trial";
      }
    }

    // Update download version note from the JWT iat as a rough hint.
    document.getElementById("downloads-version").textContent =
      "Latest stable build · sign in inside the installer.";

    // ===== Delete-account button =====
    const delBtn = document.getElementById("delete-account-btn");
    const delStatus = document.getElementById("delete-status");
    if (delBtn && delStatus) {
      delBtn.addEventListener("click", async () => {
        const confirmed = window.confirm(
          "Delete your BoltMate account?\n\nThis wipes your license and every refresh log row. You can re-sign-up later, but this machine may still be inside its 12-month trial-reuse cool-off."
        );
        if (!confirmed) return;
        delStatus.textContent = "Deleting…";
        delStatus.className = "delete-status";
        delBtn.disabled = true;
        try {
          const r = await fetch("/api/entitlement", {
            method: "DELETE",
            headers: { authorization: "Bearer " + idToken },
          });
          if (r.status === 204 || r.ok) {
            delStatus.textContent = "Deleted. Signing you out…";
            delStatus.classList.add("ok");
            setTimeout(() => {
              window.location.href = "/.auth/logout?post_logout_redirect_uri=/";
            }, 1200);
          } else {
            delStatus.textContent = "Couldn't delete (status " + r.status + "). Email support@boltmate.app.";
            delStatus.classList.add("err");
            delBtn.disabled = false;
          }
        } catch (e) {
          delStatus.textContent = "Network error — try again.";
          delStatus.classList.add("err");
          delBtn.disabled = false;
        }
      });
    }

    show("account-ok");
  }

  run();
</script>

<style>
  .account-section {
    padding: 64px 0 96px;
    min-height: 60vh;
  }

  .state-card {
    background: #fff;
    border: 1px solid var(--bm-stroke);
    border-radius: 18px;
    padding: 36px 36px 32px;
    max-width: 540px;
  }
  .state-card.error { border-color: #ffd2cc; }
  .state-card h1 {
    margin: 10px 0 14px;
    font-weight: 660;
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: #161616;
  }
  .state-lede {
    margin: 0 0 22px;
    max-width: 50ch;
    font-size: 15px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }

  .account-header {
    margin-bottom: 28px;
    max-width: 720px;
  }
  .account-header h1 {
    margin: 12px 0 0;
    font-weight: 700;
    font-size: clamp(28px, 4vw, 38px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #161616;
  }
  .account-header .state-lede {
    margin: 14px 0 0;
  }

  .trial-banner {
    margin: 0 0 28px;
    background: #1c1c1e;
    border-radius: 16px;
    padding: 22px 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
    flex-wrap: wrap;
  }
  .banner-title {
    font-weight: 620;
    font-size: 16px;
    color: #f5f5f7;
  }
  .banner-body {
    margin: 4px 0 0;
    max-width: 56ch;
    font-size: 14px;
    line-height: 1.5;
    color: #a6a6ac;
  }

  /* ============================================================
     Cards grid
     ============================================================ */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  @media (max-width: 840px) {
    .cards-grid { grid-template-columns: 1fr; }
  }
  .card {
    background: #fff;
    border: 1px solid var(--bm-stroke);
    border-radius: 18px;
    padding: 28px;
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .card-eyebrow {
    font-family: var(--bm-font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--bm-fg-tertiary);
    margin: 0 0 6px;
  }
  .card-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .card h2 {
    margin: 0;
    font-weight: 660;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #161616;
  }

  /* Status badges */
  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: var(--bm-font-mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.05em;
  }
  .status-badge-trial {
    background: var(--bm-amber-bg);
    color: var(--bm-amber-fg);
  }
  .status-badge-active {
    background: #eafad9;
    color: #42701a;
  }
  .status-badge-expired {
    background: #fde2e0;
    color: #a93232;
  }

  /* License card */
  .license-fields {
    margin: 18px 0 18px;
    padding: 18px 0 0;
    border-top: 1px solid var(--bm-stroke);
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 10px 22px;
  }
  .license-fields dt {
    font-family: var(--bm-font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--bm-fg-tertiary);
    text-transform: uppercase;
  }
  .license-fields dd {
    margin: 0;
    font-size: 14px;
    color: #1d1d1f;
  }
  .license-note {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--bm-fg-tertiary);
  }

  /* Downloads card */
  .downloads-card h2 {
    margin-top: 4px;
  }
  .downloads-lede {
    margin: 6px 0 18px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }
  .download-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .download-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid var(--bm-stroke);
    border-radius: 12px;
    background: var(--bm-bg-soft);
    color: #1d1d1f;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .download-row:hover {
    border-color: #c5c5cb;
    background: #fff;
  }
  .download-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--bm-stroke);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .download-name {
    font-weight: 620;
    font-size: 14px;
    color: #161616;
  }
  .download-sub {
    font-size: 12.5px;
    color: var(--bm-fg-tertiary);
    margin-top: 2px;
  }
  .download-cta {
    font-weight: 700;
    color: var(--bm-fg-tertiary);
  }
  .downloads-version {
    margin: 14px 0 0;
    font-family: var(--bm-font-mono);
    font-size: 11.5px;
    color: var(--bm-fg-tertiary);
  }

  /* Footer / signout / danger zone */
  .account-footer {
    margin-top: 36px;
    display: grid;
    gap: 24px;
  }
  .signout-row {
    font-size: 14px;
    color: var(--bm-fg-tertiary);
    margin: 0;
  }
  .danger-zone {
    margin-top: 22px;
    padding: 22px 24px;
    border: 1px solid #ffd2cc;
    border-radius: 14px;
    background: #fff5f3;
    max-width: 760px;
  }
  .danger-zone h2 {
    margin: 0;
    font-size: 16px;
    font-weight: 660;
    color: #a93232;
  }
  .danger-zone p {
    margin: 8px 0 14px;
    font-size: 13.5px;
    line-height: 1.5;
    max-width: 60ch;
    color: var(--bm-fg-secondary);
  }
  .delete-status {
    margin: 12px 0 0;
    font-size: 13px;
    color: var(--bm-fg-secondary);
  }
  .delete-status.ok { color: #42701a; }
  .delete-status.err { color: #a93232; }
</style>
