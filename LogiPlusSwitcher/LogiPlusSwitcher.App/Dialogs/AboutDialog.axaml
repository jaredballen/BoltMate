<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LogiPlusSwitcher.App.Dialogs.AboutDialog"
        Width="440" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Title="About LogiPlusSwitcher">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <Image Grid.Row="0" Source="avares://LogiPlusSwitcher.App/Assets/app-icon-1024.png"
               Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,12" />
        <TextBlock Grid.Row="1" Text="LogiPlusSwitcher" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" />
        <TextBlock Grid.Row="2" x:Name="VersionLine" HorizontalAlignment="Center"
                   Foreground="#999" Margin="0,4,0,12" />
        <TextBlock Grid.Row="3" TextWrapping="Wrap" TextAlignment="Center" Foreground="#CCC">
            Companion to Logi Options+ — detects host-switch events on a shared Bolt receiver
            and fans the switch out to all paired peripherals.
        </TextBlock>
        <TextBlock Grid.Row="5" HorizontalAlignment="Center" Foreground="#888" FontSize="11" Margin="0,12,0,0">
            Copyright (c) Jared Ballen
        </TextBlock>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Close" Click="OnClose" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
