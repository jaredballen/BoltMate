<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BoltMate.App.UI"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:svg="using:Avalonia.Svg.Skia"
        x:Class="BoltMate.App.UI.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="860" Height="594"
        MinWidth="680" MinHeight="460"
        Title="BoltMate Settings"
        WindowStartupLocation="CenterScreen">

    <!--
        Settings shell per June 2026 design handoff §2.

        Layout:
          [ 208 px dark nav rail  | flex content pane ]

        Nav rail mirrors the Welcome wizard's left rail: same dark
        background, same logo lockup at top. Three nav items (Status /
        General / License) styled as Button.nav-item with two visual
        states driven by VM.CurrentTab — active/inactive via
        DynamicResource binds to BrandRail* tokens. Clicking fires
        SelectTabCommand with the tab key as parameter.

        Page swap is now binding-driven (each page Grid's IsVisible
        binds to the matching ShowXxxTab flag) — no more code-behind
        ShowPage indirection.

        Mac Mica is NOT enabled.
    -->
    <Window.Styles>
        <!-- Nav-item button: full-bleed across the rail, left-aligned content,
             two themed background/foreground brushes per state. -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrandRailUpcomingTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
        <Style Selector="Button.nav-item.active">
            <Setter Property="Foreground" Value="{DynamicResource BrandRailActiveTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.nav-item.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BrandRailActiveBackgroundBrush}" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="208,*"
          Background="{DynamicResource AppBackgroundBrush}">

        <!-- ====================================================== -->
        <!-- LEFT NAV RAIL                                          -->
        <!-- ====================================================== -->
        <Border Grid.Column="0"
                Background="{DynamicResource BrandRailBackgroundBrush}">
            <Grid RowDefinitions="Auto,Auto,*" Margin="20,22,20,22">

                <!-- Logo lockup -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8"
                            Background="{DynamicResource BrandBlackTileBrush}">
                        <Image Source="{SvgImage avares://BoltMate/Assets/BoltMate_logo.svg}"
                               Width="19" Height="19"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="BoltMate"
                               Foreground="White" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Hairline separator -->
                <Border Grid.Row="1" Height="1" Background="#22FFFFFF" Margin="0,18,0,12" />

                <!-- Nav items -->
                <StackPanel Grid.Row="2" Spacing="2">
                    <Button Classes.active="{Binding IsStatusActive}"
                            Classes="nav-item"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="status">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ui:FASymbolIcon Symbol="Globe" FontSize="14" />
                            <TextBlock Text="Status" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes.active="{Binding IsGeneralActive}"
                            Classes="nav-item"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="general">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ui:FASymbolIcon Symbol="Important" FontSize="14" />
                            <TextBlock Text="General" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes.active="{Binding IsLicenseActive}"
                            Classes="nav-item"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="license">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ui:FASymbolIcon Symbol="Document" FontSize="14" />
                            <TextBlock Text="License" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====================================================== -->
        <!-- RIGHT CONTENT PANE                                     -->
        <!-- ====================================================== -->
        <Grid Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}">
            <Grid>

                <!-- ======================= STATUS ======================= -->
                <Grid x:Name="StatusPage" Margin="26,24,26,24"
                      IsVisible="{Binding ShowStatusTab}"
                      RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
                        <TextBlock Text="Status"
                                   FontSize="{StaticResource FontSizeH2}" FontWeight="SemiBold"
                                   LetterSpacing="-0.3"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Your devices on this machine and the other computers BoltMate can see."
                                   FontSize="12.5" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="13">

                            <!-- ===== Card: This machine ===== -->
                            <Border BorderBrush="{DynamicResource CardStrokeBrush}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="16,15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="This machine"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <ItemsControl ItemsSource="{Binding LocalDevices}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:SettingsViewModel+LocalDeviceRow">
                                                <Border Padding="12,10"
                                                        Background="{DynamicResource RowBackgroundBrush}"
                                                        CornerRadius="{StaticResource RowCornerRadius}">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Header}"
                                                                   FontWeight="SemiBold" FontSize="13.5"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding SubLine}"
                                                                   FontSize="11"
                                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No devices linked up. Tap Easy-Switch on a keyboard or mouse to bring it over."
                                               FontSize="12"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               IsVisible="{Binding LocalEmpty}" />
                                </StackPanel>
                            </Border>

                            <!-- ===== Card: Network access (firewall / TCC roll-up) ===== -->
                            <Border BorderBrush="{DynamicResource CardStrokeBrush}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="16,15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Network access"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding NetworkPermissionDetail}"
                                               FontSize="11.5"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <Button Content="{Binding OpenNetworkSettingsLabel}"
                                            Command="{Binding OpenNetworkSettingsCommand}"
                                            IsVisible="{Binding ShowOpenNetworkSettings}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <!-- ===== Card: Network (transports) ===== -->
                            <Border BorderBrush="{DynamicResource CardStrokeBrush}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="16,15">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Network"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="The transports BoltMate uses to reach your other computers."
                                                   FontSize="11.5"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                                    </StackPanel>

                                    <!-- UDP row -->
                                    <Border Padding="12,10"
                                            Background="{DynamicResource RowBackgroundBrush}"
                                            CornerRadius="{StaticResource RowCornerRadius}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto"
                                              ColumnSpacing="9">
                                            <Ellipse Grid.Column="0" Grid.Row="0"
                                                     Width="9" Height="9"
                                                     Fill="{Binding UdpIndicatorColor}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Text="UDP multicast"
                                                       FontWeight="SemiBold" FontSize="12.5"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Grid.Row="0"
                                                       Text="{Binding UdpEndpoint}"
                                                       FontSize="11"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" TextAlignment="Right" />
                                            <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                       Text="{Binding UdpDetail}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </Grid>
                                    </Border>

                                    <!-- Sync row -->
                                    <Border Padding="12,10"
                                            Background="{DynamicResource RowBackgroundBrush}"
                                            CornerRadius="{StaticResource RowCornerRadius}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto"
                                              ColumnSpacing="9">
                                            <Ellipse Grid.Column="0" Grid.Row="0"
                                                     Width="9" Height="9"
                                                     Fill="{Binding SyncIndicatorColor}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Text="Bonjour / mDNS + TCP sync"
                                                       FontWeight="SemiBold" FontSize="12.5"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Grid.Row="0"
                                                       Text="{Binding SyncEndpoint}"
                                                       FontSize="11"
                                                       FontFamily="{StaticResource MonoFontFamily}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" TextAlignment="Right" />
                                            <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                       Text="{Binding SyncDetail}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ===== Card: Other computers ===== -->
                            <Border BorderBrush="{DynamicResource CardStrokeBrush}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="16,15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Other computers"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding PeersStateLine}"
                                               FontSize="11.5" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextTertiaryBrush}" />
                                    <ItemsControl ItemsSource="{Binding Peers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:SettingsViewModel+PeerRow">
                                                <Border Padding="12,11"
                                                        BorderBrush="{DynamicResource CardStrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource RowCornerRadius}">
                                                    <StackPanel Spacing="4">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding Header}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                            <TextBlock Grid.Column="1" Text="{Binding LastSeen}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding MetaLine}"
                                                                   FontSize="11"
                                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                                                        <ItemsControl ItemsSource="{Binding Devices}" Margin="6,2,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="vm:SettingsViewModel+PeerDeviceRow">
                                                                    <TextBlock Text="{Binding Line}"
                                                                               FontSize="11"
                                                                               FontFamily="{StaticResource MonoFontFamily}"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               Margin="0,1" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding PeersOverflowLine}"
                                               Foreground="#9AA0A6" FontSize="11"
                                               IsVisible="{Binding ShowPeersOverflow}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= ABOUT ======================= -->
                <Grid x:Name="GeneralPage" Margin="20"
                      IsVisible="{Binding ShowGeneralTab}">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="BoltMate" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding VersionLine}" Foreground="#9AA0A6" FontSize="12" />
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Updates" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Last checked:" Foreground="#9AA0A6" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LastCheckedLine}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Check for updates"
                                                Command="{Binding CheckForUpdatesCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UpdateStatusLine}"
                                               Foreground="#B5BAC2" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox Content="Launch BoltMate at login"
                                              IsChecked="{Binding LaunchAtLoginChecked, Mode=TwoWay}"
                                              IsEnabled="{Binding LaunchAtLoginEnabled}" />
                                    <TextBlock Text="{Binding LaunchAtLoginDetail}"
                                               Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Privacy" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox Content="Send anonymous diagnostics"
                                              IsChecked="{Binding TelemetryEnabled, Mode=TwoWay}" />
                                    <TextBlock Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                        Off by default. When on, error reports and de-identified usage counts go to Azure App Insights.
                                        No device serials, key strokes, or file paths are ever sent.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <!--
                                        Read-only notification status card. The toggle was removed
                                        because Win + Mac both refuse programmatic grant/revoke for
                                        non-packaged apps; an in-app toggle is a polite lie. The pill
                                        shows the live OS state via NotificationsEnabled; the button
                                        bounces the user to System Settings, which IS the toggle.
                                    -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="Notifications" FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                CornerRadius="10" Padding="10,2"
                                                VerticalAlignment="Center"
                                                Background="{Binding NotificationsPillBackground}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding NotificationsPillDot}" />
                                                <TextBlock Text="{Binding NotificationsPillText}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding NotificationsPillForeground}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                        BoltMate alerts you when something needs your attention — never for routine activity.
                                        Notifications are controlled by System Settings; BoltMate shows their current state here.
                                    </TextBlock>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding NotificationsStatusLine}"
                                                   Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="Open in System Settings"
                                                Command="{Binding OpenNotificationSettingsCommand}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Diagnostics" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open logs folder"
                                                Command="{Binding OpenLogsFolderCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding LogsPathLine}"
                                               Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= LICENSE ======================= -->
                <Grid x:Name="LicensePage" Margin="20"
                      IsVisible="{Binding ShowLicenseTab}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="License" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Licensing — coming soon" Foreground="#B5BAC2" FontSize="13" />
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Activation key" FontSize="14" FontWeight="SemiBold" />
                                <TextBox IsEnabled="False" Text="" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Activate" IsEnabled="False" />
                                </StackPanel>
                                <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                    Licensing is not yet available. The current build runs all features without an activation key.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
