<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BoltMate.App.UI"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="BoltMate.App.UI.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="820" Height="560"
        MinWidth="680" MinHeight="460"
        Title="BoltMate Settings"
        WindowStartupLocation="CenterScreen">

    <!--
        Win11-style settings shell. FluentAvalonia NavigationView on the left,
        three pages stacked in a content Grid (only one IsVisible at a time —
        page swap done in code-behind because FANavigationView's selection
        contract doesn't bind cleanly).

        All state binds to SettingsViewModel. Mac Mica is NOT enabled.
    -->
    <Grid>
        <ui:FANavigationView x:Name="MainNav"
                             PaneDisplayMode="Left"
                             IsBackButtonVisible="False"
                             IsSettingsVisible="False"
                             IsPaneToggleButtonVisible="False"
                             OpenPaneLength="200"
                             AlwaysShowHeader="False">
            <ui:FANavigationView.MenuItems>
                <ui:FANavigationViewItem x:Name="StatusNavItem"
                                         Content="Status"
                                         Tag="status">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Globe" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
                <ui:FANavigationViewItem x:Name="AboutNavItem"
                                         Content="About"
                                         Tag="about">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Important" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
                <ui:FANavigationViewItem x:Name="LicenseNavItem"
                                         Content="License"
                                         Tag="license">
                    <ui:FANavigationViewItem.IconSource>
                        <ui:FASymbolIconSource Symbol="Document" />
                    </ui:FANavigationViewItem.IconSource>
                </ui:FANavigationViewItem>
            </ui:FANavigationView.MenuItems>

            <Grid>

                <!-- ======================= STATUS ======================= -->
                <Grid x:Name="StatusPage" Margin="20" RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="Status" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                            Online devices on this machine, the local network access state, and any peers reachable on the LAN.
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="16">

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="This machine" FontSize="14" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding LocalDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:SettingsViewModel+LocalDeviceRow">
                                                <Border Padding="8" Margin="0,0,0,4"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding SubLine}"
                                                                   Foreground="#9AA0A6" FontSize="11"
                                                                   FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No devices currently linked up."
                                               Foreground="#9AA0A6" FontSize="12"
                                               IsVisible="{Binding LocalEmpty}" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Network access" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding NetworkPermissionDetail}"
                                               Foreground="#B5BAC2" FontSize="12" />
                                    <Button Content="{Binding OpenNetworkSettingsLabel}"
                                            Command="{Binding OpenNetworkSettingsCommand}"
                                            IsVisible="{Binding ShowOpenNetworkSettings}" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Network" FontSize="14" FontWeight="SemiBold" />

                                    <!-- UDP row -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="●"
                                                   Foreground="{Binding UdpIndicatorColor}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Grid.Row="0" Text="UDP multicast"
                                                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding UdpEndpoint}"
                                                   Foreground="#9AA0A6" FontSize="11"
                                                   VerticalAlignment="Center" TextAlignment="Right" />
                                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                   Text="{Binding UdpDetail}"
                                                   Foreground="#B5BAC2" FontSize="12"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </Grid>

                                    <Border Height="1"
                                            Background="{DynamicResource CardStrokeColorDefaultBrush}"
                                            Margin="0,4" />

                                    <!-- Sync row -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="●"
                                                   Foreground="{Binding SyncIndicatorColor}"
                                                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Grid.Row="0" Text="Bonjour / mDNS + TCP sync"
                                                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Grid.Row="0" Text="{Binding SyncEndpoint}"
                                                   Foreground="#9AA0A6" FontSize="11"
                                                   VerticalAlignment="Center" TextAlignment="Right" />
                                        <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                   Text="{Binding SyncDetail}"
                                                   Foreground="#B5BAC2" FontSize="12"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Peers" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PeersStateLine}"
                                               Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Peers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:SettingsViewModel+PeerRow">
                                                <Border Padding="8" Margin="0,0,0,4"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4">
                                                    <StackPanel Spacing="3">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" />
                                                            <TextBlock Grid.Column="1" Text="{Binding LastSeen}" Foreground="#9AA0A6" FontSize="11" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding MetaLine}"
                                                                   Foreground="#9AA0A6" FontSize="11"
                                                                   FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                                                        <ItemsControl ItemsSource="{Binding Devices}" Margin="6,2,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="vm:SettingsViewModel+PeerDeviceRow">
                                                                    <TextBlock Text="{Binding Line}"
                                                                               Foreground="#B5BAC2" FontSize="11"
                                                                               FontFamily="JetBrains Mono,Menlo,Consolas,monospace" Margin="0,1" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding PeersOverflowLine}"
                                               Foreground="#9AA0A6" FontSize="11"
                                               IsVisible="{Binding ShowPeersOverflow}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= ABOUT ======================= -->
                <Grid x:Name="AboutPage" Margin="20" IsVisible="False">
                    <ScrollViewer>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="BoltMate" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding VersionLine}" Foreground="#9AA0A6" FontSize="12" />
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Updates" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Last checked:" Foreground="#9AA0A6" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LastCheckedLine}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Check for updates"
                                                Command="{Binding CheckForUpdatesCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UpdateStatusLine}"
                                               Foreground="#B5BAC2" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Startup" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox Content="Launch BoltMate at login"
                                              IsChecked="{Binding LaunchAtLoginChecked, Mode=TwoWay}"
                                              IsEnabled="{Binding LaunchAtLoginEnabled}" />
                                    <TextBlock Text="{Binding LaunchAtLoginDetail}"
                                               Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Privacy" FontSize="14" FontWeight="SemiBold" />
                                    <CheckBox Content="Send anonymous diagnostics"
                                              IsChecked="{Binding TelemetryEnabled, Mode=TwoWay}" />
                                    <TextBlock Margin="22,0,0,0" Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                        Off by default. When on, error reports and de-identified usage counts go to Azure App Insights.
                                        No device serials, key strokes, or file paths are ever sent.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <!--
                                        Read-only notification status card. The toggle was removed
                                        because Win + Mac both refuse programmatic grant/revoke for
                                        non-packaged apps; an in-app toggle is a polite lie. The pill
                                        shows the live OS state via NotificationsEnabled; the button
                                        bounces the user to System Settings, which IS the toggle.
                                    -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="Notifications" FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                CornerRadius="10" Padding="10,2"
                                                VerticalAlignment="Center"
                                                Background="{Binding NotificationsPillBackground}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding NotificationsPillDot}" />
                                                <TextBlock Text="{Binding NotificationsPillText}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding NotificationsPillForeground}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                        BoltMate alerts you when something needs your attention — never for routine activity.
                                        Notifications are controlled by System Settings; BoltMate shows their current state here.
                                    </TextBlock>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding NotificationsStatusLine}"
                                                   Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="Open in System Settings"
                                                Command="{Binding OpenNotificationSettingsCommand}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Diagnostics" FontSize="14" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open logs folder"
                                                Command="{Binding OpenLogsFolderCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding LogsPathLine}"
                                               Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ======================= LICENSE ======================= -->
                <Grid x:Name="LicensePage" Margin="20" IsVisible="False">
                    <StackPanel Spacing="16">
                        <TextBlock Text="License" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Licensing — coming soon" Foreground="#B5BAC2" FontSize="13" />
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Activation key" FontSize="14" FontWeight="SemiBold" />
                                <TextBox IsEnabled="False" Text="" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Activate" IsEnabled="False" />
                                </StackPanel>
                                <TextBlock Foreground="#9AA0A6" FontSize="12" TextWrapping="Wrap">
                                    Licensing is not yet available. The current build runs all features without an activation key.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </ui:FANavigationView>
    </Grid>
</Window>
