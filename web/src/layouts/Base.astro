---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  /** When true, hide the bottom trial-expired banner regardless of localStorage. */
  hideTrialBanner?: boolean;
}

const {
  title = "BoltMate — Easy-Switch follow for the whole desk",
  description = "Press Easy-Switch on any device and the rest of your desk follows to the same computer. A companion to Logi Options+ that works right alongside Flow.",
  pathname = Astro.url.pathname,
  hideTrialBanner = false,
} = Astro.props;

const isPricing = pathname === "/pricing" || pathname.startsWith("/pricing/");
const isAccount = pathname === "/account" || pathname.startsWith("/account/");
const isCheckout = pathname === "/checkout" || pathname.startsWith("/checkout/");
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#ffffff" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://boltmate.app${pathname}`} />
  <link rel="canonical" href={`https://boltmate.app${pathname}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <!-- Sticky blurred nav per design handoff §"Site-specific tokens". -->
  <header class="site-nav">
    <div class="container nav-row">
      <a href="/" class="brand" aria-label="BoltMate home">
        <span class="bolt-mark-tile" style="width:30px;height:30px;">
          <svg viewBox="-11 -11 157 157" width="19" height="19" aria-hidden="true">
            <path d="M58.752 39.705c-14.932-.247-29.882.553-33.542 2.586C17.89 46.358-9.096 91.37-9.234 99.742s25.351 54.25 32.533 58.556c7.181 4.306 59.658 5.172 66.977 1.106 7.32-4.067 34.306-49.08 34.445-57.451.138-8.372-25.352-54.25-32.533-58.556-3.59-2.153-18.504-3.446-33.436-3.692m8.77 8.91a1.85 1.85 0 0 1 1.435.652c.283.342.51.793.506 1-.007.374-.752 4.27-3.335 17.435-.74 3.776-1.86 9.507-2.49 12.735-.63 3.229-1.348 6.868-1.598 8.086s-.42 2.276-.377 2.35l.003.004c.066.077.867.27 1.8.434 2.092.365 16.665 3.133 24.41 4.635 3.19.619 5.852 1.247 6.15 1.451.655.448.98 1.308.776 2.055-.085.312-4.984 6.137-10.885 12.943l-22.654 26.128c-6.558 7.564-12.109 13.932-12.338 14.152-.674.648-1.831.498-2.496-.326-.31-.382-.557-.884-.553-1.114s.465-2.74 1.022-5.578 1.606-8.198 2.332-11.914a4333 4333 0 0 1 3.944-20.048c.31-1.534.504-2.86.445-3.012l-.003-.003v-.003h-.003c-.078-.077-1.19-.328-2.47-.558-2.6-.467-15.113-2.85-23.64-4.503-3.072-.596-5.791-1.2-6.043-1.341-.72-.404-1.053-1.744-.666-2.676.075-.18 3.12-3.773 6.767-7.982C54.691 62.31 65.924 49.4 66.353 49.035c.332-.281.75-.418 1.17-.42z" fill="#99ff55" transform="rotate(-1.145 -744.858 -913.399)scale(.8307)" />
            <path d="M90.275 159.404c-7.32 4.066-59.796 3.2-66.977-1.105-7.182-4.306-32.67-50.185-32.532-58.557s27.126-53.385 34.446-57.451 59.796-3.2 66.977 1.105c7.181 4.306 32.67 50.185 32.531 58.557-.138 8.372-27.126 53.385-34.445 57.451z" fill="none" stroke="#99ff55" stroke-width="4.8981" transform="matrix(.9753 -.0195 .0195 .9753 9.452 -29.5)" />
          </svg>
        </span>
        <span class="brand-name">BoltMate</span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="/#how-it-works">How it works</a>
        <a href="/#privacy">Privacy</a>
        <a href="/pricing" class:list={[isPricing && "active"]}>Pricing</a>
      </nav>

      <div class="nav-cta">
        <a href="/pricing" class="btn btn-secondary">Start free trial</a>
        <a href="/checkout" class="btn btn-primary">Buy</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <div class="footer-brand">
          <span class="bolt-mark-tile" style="width:28px;height:28px;">
            <svg viewBox="-11 -11 157 157" width="18" height="18" aria-hidden="true">
              <path d="M58.752 39.705c-14.932-.247-29.882.553-33.542 2.586C17.89 46.358-9.096 91.37-9.234 99.742s25.351 54.25 32.533 58.556c7.181 4.306 59.658 5.172 66.977 1.106 7.32-4.067 34.306-49.08 34.445-57.451.138-8.372-25.352-54.25-32.533-58.556-3.59-2.153-18.504-3.446-33.436-3.692m8.77 8.91a1.85 1.85 0 0 1 1.435.652c.283.342.51.793.506 1-.007.374-.752 4.27-3.335 17.435-.74 3.776-1.86 9.507-2.49 12.735-.63 3.229-1.348 6.868-1.598 8.086s-.42 2.276-.377 2.35l.003.004c.066.077.867.27 1.8.434 2.092.365 16.665 3.133 24.41 4.635 3.19.619 5.852 1.247 6.15 1.451.655.448.98 1.308.776 2.055-.085.312-4.984 6.137-10.885 12.943l-22.654 26.128c-6.558 7.564-12.109 13.932-12.338 14.152-.674.648-1.831.498-2.496-.326-.31-.382-.557-.884-.553-1.114s.465-2.74 1.022-5.578 1.606-8.198 2.332-11.914a4333 4333 0 0 1 3.944-20.048c.31-1.534.504-2.86.445-3.012l-.003-.003v-.003h-.003c-.078-.077-1.19-.328-2.47-.558-2.6-.467-15.113-2.85-23.64-4.503-3.072-.596-5.791-1.2-6.043-1.341-.72-.404-1.053-1.744-.666-2.676.075-.18 3.12-3.773 6.767-7.982C54.691 62.31 65.924 49.4 66.353 49.035c.332-.281.75-.418 1.17-.42z" fill="#99ff55" transform="rotate(-1.145 -744.858 -913.399)scale(.8307)" />
              <path d="M90.275 159.404c-7.32 4.066-59.796 3.2-66.977-1.105-7.182-4.306-32.67-50.185-32.532-58.557s27.126-53.385 34.446-57.451 59.796-3.2 66.977 1.105c7.181 4.306 32.67 50.185 32.531 58.557-.138 8.372-27.126 53.385-34.445 57.451z" fill="none" stroke="#99ff55" stroke-width="4.8981" transform="matrix(.9753 -.0195 .0195 .9753 9.452 -29.5)" />
            </svg>
          </span>
          <span class="footer-brand-name">BoltMate</span>
        </div>
        <p class="footer-blurb">Let the keyboard lead the switch — press Easy-Switch on any device and the rest of your desk follows. A companion to Logi Options+ that works right alongside Flow.</p>
      </div>
      <div>
        <div class="footer-heading">PRODUCT</div>
        <ul class="footer-list">
          <li><a href="/#how-it-works">How it works</a></li>
          <li><a href="/#privacy">Privacy</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/checkout">Download</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-heading">SUPPORT</div>
        <ul class="footer-list">
          <li><a href="/support">Contact</a></li>
          <li><a href="/privacy">Privacy policy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/account">Account</a></li>
        </ul>
      </div>
    </div>
    <div class="container footer-bottom">
      <p>© BoltMate. Logitech, Logi, Bolt, and Logi Options+ are trademarks of Logitech Inc. BoltMate is an independent project and is not affiliated with, endorsed by, or sponsored by Logitech.</p>
    </div>
  </footer>
</body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.82);
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--bm-stroke);
  }
  .nav-row {
    display: flex;
    align-items: center;
    height: 62px;
    gap: 26px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--bm-fg);
    font-weight: 650;
    letter-spacing: -0.01em;
  }
  .brand-name { font-size: 16px; line-height: 1; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    margin-left: 8px;
  }
  .nav-links a {
    font-weight: 450;
    font-size: 13.5px;
    line-height: 1;
    color: #4a4a4f;
    transition: color 120ms ease;
  }
  .nav-links a:hover, .nav-links a.active {
    color: var(--bm-fg);
  }
  .nav-cta {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 760px) {
    .nav-links { display: none; }
    .nav-row { height: 58px; gap: 16px; }
  }

  /* ============================================================
     Footer
     ============================================================ */
  .site-footer {
    border-top: 1px solid var(--bm-stroke);
    background: var(--bm-bg-soft);
    padding-block: 46px 22px;
    margin-top: 80px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 32px;
    padding-bottom: 28px;
  }
  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 26px; }
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 13px;
  }
  .footer-brand-name {
    font-weight: 650;
    font-size: 15px;
    color: var(--bm-fg);
  }
  .footer-blurb {
    max-width: 280px;
    font-size: 12.5px;
    line-height: 1.55;
    color: #86868b;
  }
  .footer-heading {
    font-family: var(--bm-font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--bm-fg-tertiary);
    margin-bottom: 14px;
  }
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .footer-list a {
    font-weight: 450;
    font-size: 13px;
    line-height: 1;
    color: #4a4a4f;
  }
  .footer-list a:hover { color: var(--bm-fg); }
  .footer-bottom {
    border-top: 1px solid var(--bm-stroke);
    padding-top: 22px;
  }
  .footer-bottom p {
    font-size: 11.5px;
    line-height: 1.55;
    color: var(--bm-fg-tertiary);
    max-width: 760px;
    margin: 0;
  }
</style>
