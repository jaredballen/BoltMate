---
import Base from "../layouts/Base.astro";
import { loadPricing } from "../lib/pricing.ts";

const pricing = await loadPricing();
const TRIAL_DAYS = 14;
---

<Base
  title="BoltMate — Let the keyboard lead. The whole desk follows."
  description="Press Easy-Switch on any device — keyboard or mouse — and the rest of your desk follows to the same computer. A companion to Logi Options+ that works alongside Flow."
  pathname="/"
>
  <!-- ===== HERO · Brandful (centered dark radial) ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-tile" aria-hidden="true">
        <svg viewBox="-11 -11 157 157" width="58" height="58">
          <path d="M58.752 39.705c-14.932-.247-29.882.553-33.542 2.586C17.89 46.358-9.096 91.37-9.234 99.742s25.351 54.25 32.533 58.556c7.181 4.306 59.658 5.172 66.977 1.106 7.32-4.067 34.306-49.08 34.445-57.451.138-8.372-25.352-54.25-32.533-58.556-3.59-2.153-18.504-3.446-33.436-3.692m8.77 8.91a1.85 1.85 0 0 1 1.435.652c.283.342.51.793.506 1-.007.374-.752 4.27-3.335 17.435-.74 3.776-1.86 9.507-2.49 12.735-.63 3.229-1.348 6.868-1.598 8.086s-.42 2.276-.377 2.35l.003.004c.066.077.867.27 1.8.434 2.092.365 16.665 3.133 24.41 4.635 3.19.619 5.852 1.247 6.15 1.451.655.448.98 1.308.776 2.055-.085.312-4.984 6.137-10.885 12.943l-22.654 26.128c-6.558 7.564-12.109 13.932-12.338 14.152-.674.648-1.831.498-2.496-.326-.31-.382-.557-.884-.553-1.114s.465-2.74 1.022-5.578 1.606-8.198 2.332-11.914a4333 4333 0 0 1 3.944-20.048c.31-1.534.504-2.86.445-3.012l-.003-.003v-.003h-.003c-.078-.077-1.19-.328-2.47-.558-2.6-.467-15.113-2.85-23.64-4.503-3.072-.596-5.791-1.2-6.043-1.341-.72-.404-1.053-1.744-.666-2.676.075-.18 3.12-3.773 6.767-7.982C54.691 62.31 65.924 49.4 66.353 49.035c.332-.281.75-.418 1.17-.42z" fill="#99ff55" transform="rotate(-1.145 -744.858 -913.399)scale(.8307)" />
          <path d="M90.275 159.404c-7.32 4.066-59.796 3.2-66.977-1.105-7.182-4.306-32.67-50.185-32.532-58.557s27.126-53.385 34.446-57.451 59.796-3.2 66.977 1.105c7.181 4.306 32.67 50.185 32.531 58.557-.138 8.372-27.126 53.385-34.445 57.451z" fill="none" stroke="#99ff55" stroke-width="4.8981" transform="matrix(.9753 -.0195 .0195 .9753 9.452 -29.5)" />
        </svg>
      </div>

      <div class="hero-eyebrow">LET THE KEYBOARD LEAD · WORKS WITH FLOW</div>
      <h1 class="hero-headline">
        Let the keyboard lead.<br />
        <span class="hero-headline-accent">The whole desk follows.</span>
      </h1>
      <p class="hero-lede">
        Press Easy-Switch on any device — keyboard or mouse — and the rest
        follow to the same computer. The keyboard can finally lead the
        switch, it's flexible enough to start anywhere, and it runs right
        alongside Flow.
      </p>
      <div class="hero-cta">
        <a href="/pricing" class="btn btn-primary-on-dark">Start free trial</a>
        <a href="/checkout" class="btn btn-secondary-on-dark">Buy lifetime — {pricing.amount}</a>
      </div>
      <p class="hero-fineprint">macOS 12+ · Windows 11 · works alongside Flow · nothing leaves your network</p>
    </div>

    <!-- Device card -->
    <div class="hero-card-wrap">
      <div class="hero-card">
        <div class="hero-card-head">
          <span class="hero-card-eyebrow">KEYBOARD-FIRST</span>
          <span class="hero-card-status"><span class="hero-card-status-dot"></span>SYNCED</span>
        </div>
        <div class="hero-card-tiles">
          <div class="hero-tile-idle">
            <div class="hero-tile-name">MacBook&nbsp;Pro</div>
            <div class="hero-tile-meta">macOS · idle</div>
          </div>
          <div class="hero-tile-active">
            <div class="hero-tile-name">Studio&nbsp;PC</div>
            <div class="hero-tile-meta">Windows · active</div>
          </div>
        </div>
        <div class="hero-track">
          <div class="hero-track-line"></div>
          <div class="hero-track-pill">
            <svg viewBox="0 0 24 24" width="13" height="13">
              <rect x="2.5" y="6.5" width="19" height="11" rx="2" fill="none" stroke="#99ff55" stroke-width="1.7" />
              <path d="M6 10h.01M9 10h.01M12 10h.01M15 10h.01M18 10h.01M7.5 13.5h9" fill="none" stroke="#99ff55" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <svg viewBox="0 0 24 24" width="13" height="13">
              <rect x="7" y="3" width="10" height="18" rx="5" fill="none" stroke="#99ff55" stroke-width="1.7" />
              <path d="M12 6.5v4" fill="none" stroke="#99ff55" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span>mouse follows</span>
          </div>
        </div>
        <div class="hero-card-foot">
          <div class="hero-card-chip">
            <svg viewBox="0 0 24 24" width="14" height="14">
              <rect x="2.5" y="6.5" width="19" height="11" rx="2" fill="none" stroke="currentColor" stroke-width="1.6" />
              <path d="M7.5 13.5h9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
            <span>MX&nbsp;Keys</span>
          </div>
          <div class="hero-card-chip">
            <svg viewBox="0 0 24 24" width="14" height="14">
              <rect x="7" y="3" width="10" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.6" />
            </svg>
            <span>MX&nbsp;Master</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="how-section">
    <div class="container">
      <div class="how-intro">
        <p class="eyebrow">HOW IT WORKS</p>
        <h2 class="section-h">One switch event. Everything follows.</h2>
        <p class="section-p">
          Your Bolt devices already hop between three computers with
          Easy-Switch, and Flow already follows your mouse to the screen
          edge. BoltMate ties them together: press Easy-Switch on any
          device — keyboard or mouse — and the rest follow to the same
          machine. Flow keeps working right alongside it.
        </p>
      </div>
      <div class="how-grid">
        <article class="how-card">
          <div class="how-num">1</div>
          <h3>You switch — from any device</h3>
          <p>Press Easy-Switch on your keyboard or your mouse to hop computers. Let the keyboard lead, or start anywhere — Flow still works too.</p>
        </article>
        <article class="how-card">
          <div class="how-num">2</div>
          <h3>BoltMate catches it</h3>
          <p>It reads the host-switch from your Bolt devices — and hears the same event from your other computers over the LAN.</p>
        </article>
        <article class="how-card">
          <div class="how-num how-num-accent">3</div>
          <h3>The rest follow</h3>
          <p>Every other paired device lands on the same computer, instantly — no reaching across the desk, no second button to press.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== PRIVACY band ===== -->
  <section id="privacy" class="privacy-section">
    <div class="container privacy-grid">
      <div>
        <p class="eyebrow eyebrow-on-dark">PRIVATE BY DESIGN</p>
        <h2 class="section-h-on-dark">Nothing ever leaves your network.</h2>
        <p class="section-p-on-dark">BoltMate is a companion to Logi Options+, not a replacement — and it does its one job without phoning home.</p>
      </div>
      <div class="privacy-cards">
        <div class="privacy-card">
          <div class="privacy-icon">
            <svg viewBox="0 0 24 24" width="19" height="19" stroke="#99ff55" fill="none">
              <circle cx="12" cy="12" r="9" stroke-width="1.6" />
              <path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18" stroke-width="1.3" />
            </svg>
          </div>
          <div>
            <div class="privacy-title">LAN-only, always</div>
            <p class="privacy-body">Devices coordinate with tiny heartbeats on your local network. No cloud, no relay — no traffic crosses the internet.</p>
          </div>
        </div>
        <div class="privacy-card">
          <div class="privacy-icon">
            <svg viewBox="0 0 24 24" width="19" height="19" stroke="#99ff55" fill="none">
              <rect x="2.5" y="6.5" width="19" height="11" rx="2" stroke-width="1.6" />
              <path d="M6 10h.01M9 10h.01M12 10h.01M15 10h.01M18 10h.01M7.5 13.5h9" stroke-width="1.6" stroke-linecap="round" />
            </svg>
          </div>
          <div>
            <div class="privacy-title">No keystroke logging</div>
            <p class="privacy-body">macOS calls the permission "Input Monitoring," but BoltMate uses it only to notice Easy-Switch presses. It never reads what you type.</p>
          </div>
        </div>
        <div class="privacy-card">
          <div class="privacy-icon">
            <svg viewBox="0 0 24 24" width="19" height="19" stroke="#99ff55" fill="none">
              <path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6z" stroke-width="1.6" stroke-linejoin="round" />
              <path d="M8.8 12l2.2 2.2 4.2-4.4" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div>
            <div class="privacy-title">Your license, not a tracker</div>
            <p class="privacy-body">Sign in once to own it across all your computers. We don't sell data — there's nothing to sell.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRICING TEASER ===== -->
  <section class="pricing-teaser">
    <div class="container">
      <div class="pricing-intro">
        <p class="eyebrow">PRICING</p>
        <h2 class="section-h">Try it free. Buy it once.</h2>
        <p class="section-p">No subscription. One purchase, licensed to you — sign in on every computer you own.</p>
      </div>
      <div class="price-cards">
        <article class="price-card price-card-light">
          <div class="price-card-title">Free trial</div>
          <div class="price-card-amount">
            <span class="price-card-num">$0</span>
            <span class="price-card-unit">for {TRIAL_DAYS} days</span>
          </div>
          <p class="price-card-body">Every feature, unlocked. No card required — just download and go.</p>
          <ul class="price-card-list">
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>All cross-device fan-out</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>macOS and Windows</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#7fbf3f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>No commitment — decide later</li>
          </ul>
          <a href="/pricing" class="btn btn-secondary-lg price-card-cta">Start free trial</a>
        </article>
        <article class="price-card price-card-dark">
          <span class="price-card-pill">ONE-TIME</span>
          <div class="price-card-title-light">Lifetime license</div>
          <div class="price-card-amount">
            <span class="price-card-num-light">{pricing.amount}</span>
            <span class="price-card-unit-light">once</span>
          </div>
          <p class="price-card-body-light">Buy once. Yours forever — every future update included.</p>
          <ul class="price-card-list-light">
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Everything in the trial</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Licensed to your account — no keys</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Use on all your Macs and PCs</li>
            <li><svg viewBox="0 0 16 16" width="14" height="14"><path d="M3.4 8.4l3 3 6.2-7" fill="none" stroke="#99ff55" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>Every future update</li>
          </ul>
          <a href="/checkout" class="btn btn-green price-card-cta">Buy lifetime — {pricing.amount}</a>
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: radial-gradient(110% 80% at 50% -10%, #26271f, #1c1c1e 55%, #161618);
    padding: 76px 28px 72px;
    text-align: center;
  }
  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    animation: bm-rise 0.5s ease both;
  }
  .hero-tile {
    width: 92px;
    height: 92px;
    margin: 0 auto 26px;
    border-radius: 24px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 60px rgba(153, 255, 85, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    animation: bm-glow 3.4s ease-in-out infinite;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 11px;
    border-radius: 20px;
    background: rgba(153, 255, 85, 0.12);
    font-family: var(--bm-font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #bdf58c;
    margin-bottom: 22px;
  }
  .hero-headline {
    margin: 0;
    font-weight: 700;
    font-size: clamp(36px, 6vw, 60px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: #f7f7f7;
  }
  .hero-headline-accent { color: var(--bm-green); }
  .hero-lede {
    margin: 24px auto 0;
    max-width: 548px;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.55;
    color: #a6a6ac;
  }
  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    margin-top: 34px;
    flex-wrap: wrap;
  }
  .hero-fineprint {
    margin-top: 20px;
    font-family: var(--bm-font-mono);
    font-weight: 450;
    font-size: 12.5px;
    line-height: 1.4;
    color: #73746a;
  }

  .hero-card-wrap {
    max-width: 560px;
    margin: 52px auto 0;
    padding: 0 28px;
    animation: bm-rise 0.6s ease 0.1s both;
  }
  .hero-card {
    width: 100%;
    max-width: 392px;
    margin: 0 auto;
    border-radius: 20px;
    background: #fff;
    border: 1px solid var(--bm-stroke);
    box-shadow: 0 26px 64px -26px rgba(0, 0, 0, 0.5);
    padding: 22px 22px 20px;
  }
  .hero-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    font-family: var(--bm-font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
  }
  .hero-card-eyebrow { color: var(--bm-fg-tertiary); }
  .hero-card-status { color: var(--bm-green-deep); display: inline-flex; align-items: center; gap: 6px; }
  .hero-card-status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--bm-green-mid); }
  .hero-card-tiles { display: flex; gap: 12px; }
  .hero-tile-idle, .hero-tile-active { flex: 1; border-radius: 13px; padding: 13px; }
  .hero-tile-idle { border: 1px solid var(--bm-stroke); background: var(--bm-bg-soft); opacity: 0.62; }
  .hero-tile-idle .hero-tile-name { color: #86868b; }
  .hero-tile-idle .hero-tile-meta { color: var(--bm-fg-quaternary); }
  .hero-tile-active { border: 1.5px solid var(--bm-green); background: var(--bm-green-tile-bg); box-shadow: 0 0 0 4px var(--bm-green-tint-12); }
  .hero-tile-active .hero-tile-name { color: #161616; }
  .hero-tile-active .hero-tile-meta { color: var(--bm-green-deep); }
  .hero-tile-name { font-weight: 620; font-size: 12.5px; line-height: 1.1; }
  .hero-tile-meta { font-family: var(--bm-font-mono); font-weight: 400; font-size: 10px; line-height: 1; margin-top: 5px; }

  .hero-track { position: relative; height: 46px; margin: 8px 0; }
  .hero-track-line {
    position: absolute; top: 50%; left: 14px; right: 14px; height: 2px; border-radius: 2px;
    background: linear-gradient(90deg, var(--bm-stroke), var(--bm-green-soft));
    transform: translateY(-50%);
  }
  .hero-track-pill {
    position: absolute; top: 50%; transform: translate(-50%, -50%);
    animation: bm-travel 3.8s ease-in-out infinite;
    display: flex; align-items: center; gap: 8px;
    padding: 7px 12px; border-radius: 22px; background: #1c1c1e;
    box-shadow: 0 8px 18px -5px rgba(0, 0, 0, 0.45);
    white-space: nowrap; color: var(--bm-green);
  }
  .hero-track-pill span { font-weight: 600; font-size: 10.5px; line-height: 1; }

  .hero-card-foot { display: flex; gap: 7px; }
  .hero-card-chip {
    flex: 1; display: flex; align-items: center; gap: 7px;
    padding: 8px 10px; border-radius: 10px;
    background: var(--bm-bg-soft); border: 1px solid #f0f0f3;
    color: var(--bm-fg-secondary);
    font-weight: 500; font-size: 11px; line-height: 1.1;
  }
  .hero-card-chip span { color: #3a3a3c; }

  .how-section { padding: 84px 0 24px; }
  .how-intro { max-width: 640px; }
  .section-h {
    margin: 14px 0 0;
    font-weight: 660;
    font-size: clamp(28px, 4vw, 36px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #161616;
  }
  .section-p {
    margin: 16px 0 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--bm-fg-secondary);
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 42px;
  }
  @media (max-width: 760px) { .how-grid { grid-template-columns: 1fr; } }
  .how-card {
    border: 1px solid var(--bm-stroke);
    border-radius: var(--bm-radius-lg);
    background: var(--bm-bg-soft);
    padding: 26px 24px;
  }
  .how-num {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: #1c1c1e;
    color: var(--bm-green);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--bm-font-mono);
    font-weight: 700; font-size: 15px;
    margin-bottom: 18px;
  }
  .how-num-accent { background: var(--bm-green); color: var(--bm-green-on-dark); }
  .how-card h3 { margin: 0; font-weight: 620; font-size: 17px; line-height: 1.25; color: #161616; }
  .how-card p { margin: 9px 0 0; font-size: 14px; line-height: 1.55; color: #6e6e73; }

  .privacy-section { background: #1c1c1e; margin-top: 80px; }
  .privacy-grid {
    padding: 80px var(--bm-gutter);
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 54px;
    align-items: start;
  }
  @media (max-width: 760px) { .privacy-grid { grid-template-columns: 1fr; gap: 32px; } }
  .section-h-on-dark {
    margin: 14px 0 0;
    font-weight: 660;
    font-size: clamp(28px, 4vw, 36px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #f7f7f7;
  }
  .section-p-on-dark { margin: 16px 0 0; max-width: 340px; font-size: 15.5px; line-height: 1.55; color: #a6a6ac; }
  .privacy-cards { display: flex; flex-direction: column; gap: 14px; }
  .privacy-card {
    display: flex; gap: 15px;
    padding: 20px 22px;
    border-radius: 14px;
    background: var(--bm-dark-elev);
    border: 1px solid var(--bm-dark-stroke);
  }
  .privacy-icon {
    width: 34px; height: 34px; flex: none;
    border-radius: 10px;
    background: var(--bm-green-tint-14);
    display: flex; align-items: center; justify-content: center;
  }
  .privacy-title { font-weight: 620; font-size: 15px; line-height: 1.3; color: #f5f5f7; }
  .privacy-body { margin: 5px 0 0; font-size: 13.5px; line-height: 1.5; color: #a6a6ac; }

  .pricing-teaser { padding: 84px 0; }
  .pricing-intro { text-align: center; max-width: 560px; margin: 0 auto 40px; }
  .pricing-intro .eyebrow { color: var(--bm-green-mid); margin-bottom: 14px; }
  .price-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    max-width: 760px;
    margin: 0 auto;
    align-items: stretch;
  }
  @media (max-width: 760px) { .price-cards { grid-template-columns: 1fr; } }
  .price-card {
    padding: 30px 28px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .price-card-light { background: #fff; border: 1px solid #e6e6ea; }
  .price-card-dark { background: #1c1c1e; color: #fff; box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.55); }
  .price-card-title { font-weight: 620; font-size: 16px; line-height: 1; color: #161616; }
  .price-card-title-light { font-weight: 620; font-size: 16px; line-height: 1; color: #f5f5f7; }
