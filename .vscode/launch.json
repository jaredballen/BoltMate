{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI: monitor",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "program": "${workspaceFolder}/src/BoltMate.Cli/bin/Debug/net9.0/BoltMate.Cli.dll",
      "args": ["monitor", "--verbose"],
      "cwd": "${workspaceFolder}/src/BoltMate.Cli",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "CLI: list",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "program": "${workspaceFolder}/src/BoltMate.Cli/bin/Debug/net9.0/BoltMate.Cli.dll",
      "args": ["list"],
      "cwd": "${workspaceFolder}/src/BoltMate.Cli",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "CLI: diag",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "program": "${workspaceFolder}/src/BoltMate.Cli/bin/Debug/net9.0/BoltMate.Cli.dll",
      "args": ["diag"],
      "cwd": "${workspaceFolder}/src/BoltMate.Cli",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "App: tray (Avalonia)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-app",
      "program": "${workspaceFolder}/src/BoltMate.App/bin/Debug/net10.0/BoltMate.App.dll",
      "cwd": "${workspaceFolder}/src/BoltMate.App",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    }
  ]
}
