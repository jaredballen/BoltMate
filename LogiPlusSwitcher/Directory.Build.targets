<Project>

  <!--
    Stage libhidapi next to every project's output (and publish) assemblies so
    .NET's default DllImport search (AssemblyDirectory) finds it without
    DYLD_*_PATH hacks. Two responsibilities:
      - macOS dev: copy /opt/homebrew/lib/libhidapi.dylib (Apple Silicon) or
        /usr/local/lib/libhidapi.dylib (Intel) — install via `brew install hidapi`.
      - macOS publish: same dylib bundled into the publish output so the
        artifact is self-contained.
      - Windows: search common install locations for hidapi.dll. For builds in
        CI we'll pull this from a NuGet (hidapi-VC) or vcpkg in a follow-up.
  -->

  <Target Name="StageLibHidApiMacOnBuild"
          AfterTargets="Build"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'">
    <CallTarget Targets="_StageLibHidApiMacCore">
      <Output PropertyName="_DropDir" TaskParameter="TargetOutputs" />
    </CallTarget>
    <PropertyGroup>
      <_StageLibHidApiDestination>$(OutputPath)</_StageLibHidApiDestination>
    </PropertyGroup>
    <Copy SourceFiles="$(ResolvedHidApiMacSource)"
          DestinationFolder="$(_StageLibHidApiDestination)"
          SkipUnchangedFiles="true"
          Condition="'$(ResolvedHidApiMacSource)' != ''" />
  </Target>

  <Target Name="StageLibHidApiMacOnPublish"
          AfterTargets="Publish"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'">
    <CallTarget Targets="_StageLibHidApiMacCore" />
    <Copy SourceFiles="$(ResolvedHidApiMacSource)"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true"
          Condition="'$(ResolvedHidApiMacSource)' != ''" />
  </Target>

  <Target Name="_StageLibHidApiMacCore">
    <PropertyGroup>
      <BrewArmHidApi>/opt/homebrew/lib/libhidapi.dylib</BrewArmHidApi>
      <BrewIntelHidApi>/usr/local/lib/libhidapi.dylib</BrewIntelHidApi>
      <ResolvedHidApiMacSource Condition="Exists('$(BrewArmHidApi)')">$(BrewArmHidApi)</ResolvedHidApiMacSource>
      <ResolvedHidApiMacSource Condition="'$(ResolvedHidApiMacSource)' == '' AND Exists('$(BrewIntelHidApi)')">$(BrewIntelHidApi)</ResolvedHidApiMacSource>
    </PropertyGroup>
    <Warning Text="libhidapi.dylib not found at standard Homebrew paths. Run 'brew install hidapi'." Condition="'$(ResolvedHidApiMacSource)' == ''" />
  </Target>

  <!--
    Windows: AfterTargets="Build" + AfterTargets="Publish" hooks were silently
    skipped on Win 11 arm64 even with the OS condition matching — root cause
    not yet pinned down. Workaround: resolve the path eagerly during project
    evaluation (BeforeTargets="BeforeBuild") and add it as a Content item so
    the standard SDK copy logic stages it to both OutputPath and PublishDir.
  -->
  <Target Name="_ResolveWindowsHidApiBeforeBuild"
          BeforeTargets="BeforeBuild;BeforeCompile;PrepareForRun"
          Condition="'$(OS)' == 'Windows_NT'">
    <CallTarget Targets="_StageLibHidApiWindowsCore" />
    <ItemGroup Condition="'$(ResolvedHidApiWindowsSource)' != ''">
      <Content Include="$(ResolvedHidApiWindowsSource)">
        <Link>hidapi.dll</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        <Visible>false</Visible>
      </Content>
    </ItemGroup>
  </Target>

  <!--
    macOS .app bundle build: when publishing LogiPlusSwitcher.App for osx-*,
    wrap the publish output in a proper .app directory with Info.plist so the
    binary behaves as a real Mac menubar app (LSUIElement) and can be code-
    signed / notarized.
  -->
  <Target Name="StageMacAppBundle"
          AfterTargets="Publish"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'
                     AND ('$(RuntimeIdentifier)' == 'osx-arm64' OR '$(RuntimeIdentifier)' == 'osx-x64')
                     AND '$(AssemblyName)' == 'LogiPlusSwitcher.App'">
    <PropertyGroup>
      <!-- Use a subdir so we don't collide with the build-output executable
           (named LogiPlusSwitcher.App, which on a case-insensitive volume
           clashes with LogiPlusSwitcher.app). -->
      <_AppBundlePath>$([System.IO.Path]::GetFullPath('$(PublishDir)../app-bundle/LogiPlusSwitcher.app'))</_AppBundlePath>
      <_AppContents>$(_AppBundlePath)/Contents</_AppContents>
      <_AppMacOS>$(_AppContents)/MacOS</_AppMacOS>
      <_AppResources>$(_AppContents)/Resources</_AppResources>
    </PropertyGroup>

    <RemoveDir Directories="$(_AppBundlePath)" Condition="Exists('$(_AppBundlePath)')" />
    <Exec Command="mkdir -p &quot;$(_AppMacOS)&quot; &quot;$(_AppResources)&quot;" />

    <ItemGroup>
      <_PublishedFiles Include="$(PublishDir)**\*" Exclude="$(PublishDir)Assets\**\*;$(PublishDir)*.icns" />
      <_IconFile Include="$(PublishDir)Assets\LogiPlusSwitcher.icns" />
      <_IconFile Include="$(PublishDir)LogiPlusSwitcher.icns" />
    </ItemGroup>
    <Copy SourceFiles="@(_PublishedFiles)" DestinationFolder="$(_AppMacOS)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_IconFile)" DestinationFolder="$(_AppResources)" SkipUnchangedFiles="true" Condition="Exists('%(_IconFile.Identity)')" />

    <WriteLinesToFile
        File="$(_AppContents)/Info.plist"
        Overwrite="true"
        Lines="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;;&lt;!DOCTYPE plist PUBLIC &quot;-//Apple//DTD PLIST 1.0//EN&quot; &quot;http://www.apple.com/DTD/PropertyList-1.0.dtd&quot;&gt;;&lt;plist version=&quot;1.0&quot;&gt;;&lt;dict&gt;;  &lt;key&gt;CFBundleIdentifier&lt;/key&gt;;  &lt;string&gt;com.jaredballen.LogiPlusSwitcher&lt;/string&gt;;  &lt;key&gt;CFBundleName&lt;/key&gt;;  &lt;string&gt;LogiPlusSwitcher&lt;/string&gt;;  &lt;key&gt;CFBundleDisplayName&lt;/key&gt;;  &lt;string&gt;LogiPlus Switcher&lt;/string&gt;;  &lt;key&gt;CFBundleExecutable&lt;/key&gt;;  &lt;string&gt;LogiPlusSwitcher.App&lt;/string&gt;;  &lt;key&gt;CFBundleIconFile&lt;/key&gt;;  &lt;string&gt;LogiPlusSwitcher.icns&lt;/string&gt;;  &lt;key&gt;CFBundleVersion&lt;/key&gt;;  &lt;string&gt;$(Version)&lt;/string&gt;;  &lt;key&gt;CFBundleShortVersionString&lt;/key&gt;;  &lt;string&gt;$(Version)&lt;/string&gt;;  &lt;key&gt;CFBundlePackageType&lt;/key&gt;;  &lt;string&gt;APPL&lt;/string&gt;;  &lt;key&gt;LSMinimumSystemVersion&lt;/key&gt;;  &lt;string&gt;11.0&lt;/string&gt;;  &lt;key&gt;LSUIElement&lt;/key&gt;;  &lt;true/&gt;;  &lt;key&gt;NSHumanReadableCopyright&lt;/key&gt;;  &lt;string&gt;Copyright (c) Jared Ballen&lt;/string&gt;;  &lt;key&gt;NSHighResolutionCapable&lt;/key&gt;;  &lt;true/&gt;;&lt;/dict&gt;;&lt;/plist&gt;" />

    <Exec Command="chmod +x &quot;$(_AppMacOS)/LogiPlusSwitcher.App&quot;" IgnoreExitCode="true" />

    <Message Importance="high" Text="Built macOS app bundle: $(_AppBundlePath)" />
  </Target>

  <Target Name="_StageLibHidApiWindowsCore">
    <PropertyGroup>
      <!-- Common Windows install locations. Override $(HidApiWindowsPath) in
           a developer-local Directory.Build.props if libhidapi lives elsewhere. -->
      <WindowsSysHidApi>$(WINDIR)\System32\hidapi.dll</WindowsSysHidApi>
      <VcpkgHidApi>C:\vcpkg\installed\x64-windows\bin\hidapi.dll</VcpkgHidApi>
      <ResolvedHidApiWindowsSource Condition="'$(HidApiWindowsPath)' != '' AND Exists('$(HidApiWindowsPath)')">$(HidApiWindowsPath)</ResolvedHidApiWindowsSource>
      <ResolvedHidApiWindowsSource Condition="'$(ResolvedHidApiWindowsSource)' == '' AND Exists('$(VcpkgHidApi)')">$(VcpkgHidApi)</ResolvedHidApiWindowsSource>
      <ResolvedHidApiWindowsSource Condition="'$(ResolvedHidApiWindowsSource)' == '' AND Exists('$(WindowsSysHidApi)')">$(WindowsSysHidApi)</ResolvedHidApiWindowsSource>
    </PropertyGroup>
    <Warning Text="hidapi.dll not found. Install via vcpkg (vcpkg install hidapi) or set HidApiWindowsPath in Directory.Build.props." Condition="'$(ResolvedHidApiWindowsSource)' == ''" />
  </Target>

</Project>
