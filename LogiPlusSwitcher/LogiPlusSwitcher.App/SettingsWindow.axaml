<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="using:LogiPlusSwitcher.App"
        x:Class="LogiPlusSwitcher.App.SettingsWindow"
        Width="720" Height="560"
        MinWidth="520" MinHeight="400"
        Title="LogiPlusSwitcher Settings"
        WindowStartupLocation="CenterScreen">

    <TabControl Margin="12">
        <!-- General tab -->
        <TabItem Header="General">
            <ScrollViewer>
                <StackPanel Margin="8" Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Startup" FontSize="16" FontWeight="Bold" />
                        <CheckBox x:Name="LaunchAtLoginToggle"
                                  Content="Launch LogiPlusSwitcher at login"
                                  IsCheckedChanged="OnLaunchAtLoginChanged" />
                        <TextBlock x:Name="LaunchAtLoginDetail"
                                   Margin="22,0,0,0" Foreground="#999" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Privacy" FontSize="16" FontWeight="Bold" />
                        <CheckBox x:Name="TelemetryToggle"
                                  Content="Send anonymous diagnostics"
                                  IsCheckedChanged="OnTelemetryChanged" />
                        <TextBlock Margin="22,0,0,0" Foreground="#999" FontSize="12" TextWrapping="Wrap">
                            Off by default. When on, error reports and de-identified usage counts go to Azure App Insights.
                            No device serials, key strokes, or file paths are ever sent.
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Diagnostics" FontSize="16" FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Open logs folder" Click="OnOpenLogsFolder" />
                            <Button Content="Open settings folder" Click="OnOpenSettingsFolder" />
                        </StackPanel>
                        <TextBlock x:Name="LogsPathLine" Foreground="#999" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Receivers tab -->
        <TabItem Header="Receivers">
            <Grid Margin="8" RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Receivers and devices" FontSize="16" FontWeight="Bold" />
                        <TextBlock x:Name="StatusLine" Foreground="#888" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Edit host labels…" Click="OnEditGlobalHostNames" VerticalAlignment="Top" />
                </Grid>

                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer>
                        <ItemsControl x:Name="ReceiverList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="app:SettingsWindow+ReceiverRow">
                                    <Border Padding="12" Margin="0,0,0,1" Background="#16FFFFFF">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Header}" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding SubLine}" FontSize="12" Foreground="#999" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Border Background="{Binding StatusBrush}" CornerRadius="3" Padding="6,2">
                                                        <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="#FFF" />
                                                    </Border>
                                                    <Button Content="Set as primary"
                                                            IsVisible="{Binding ShowSetPrimary}"
                                                            Click="OnSetPrimary"
                                                            Tag="{Binding Serial}" />
                                                    <Button Content="Hosts…"
                                                            Click="OnEditReceiverHostNames"
                                                            Tag="{Binding Serial}" />
                                                    <Button Content="Clear all pairings"
                                                            Foreground="#E57373"
                                                            Click="OnClearAllPairings"
                                                            Tag="{Binding Serial}" />
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Slots}" Margin="12,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="app:SettingsWindow+SlotRow">
                                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                                            <TextBlock Grid.Column="0" Text="{Binding Line}"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="JetBrains Mono,Menlo,Consolas,monospace" FontSize="12" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                                <Button Content="Identify"
                                                                        IsEnabled="{Binding CanIdentify}"
                                                                        Click="OnIdentifySlot"
                                                                        Tag="{Binding}" />
                                                                <Button Content="Rename…"
                                                                        IsEnabled="{Binding CanRename}"
                                                                        Click="OnRenameSlot"
                                                                        Tag="{Binding}" />
                                                                <Button Content="Unpair"
                                                                        Foreground="#E57373"
                                                                        Click="OnUnpairSlot"
                                                                        Tag="{Binding}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                    <Button Content="Refresh" Click="OnRefresh" />
                    <Button Content="Close" Click="OnClose" />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Topology tab -->
        <TabItem Header="Topology">
            <Grid Margin="8" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#CCC">
                    Each row is a paired device. Each column is a host (receiver) that some device has a slot mapped to.
                    The cell shows the device's slot number that points to that host. Empty = device isn't paired to that host.
                </TextBlock>
                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer>
                        <ItemsControl x:Name="TopologyList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="app:SettingsWindow+TopologyRow">
                                    <Border Padding="8" Margin="0,0,0,1" Background="#10FFFFFF">
                                        <TextBlock Text="{Binding Line}" FontFamily="JetBrains Mono,Menlo,Consolas,monospace" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

        <!-- Network tab -->
        <TabItem Header="Network">
            <ScrollViewer>
                <StackPanel Margin="8" Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Cross-machine sync" FontSize="16" FontWeight="Bold" />
                        <TextBlock Foreground="#CCC" TextWrapping="Wrap">
                            When enabled, LogiPlusSwitcher on this machine broadcasts a small UDP packet on the LAN
                            describing which Bolt receivers are attached and which paired devices are online.
                            Peers running this app correlate against their own link-state events: when a Bolt device
                            suddenly appears on a remote machine, the local app fans out the remaining devices so the
                            whole set follows.
                        </TextBlock>
                        <TextBlock Foreground="#999" FontSize="12" TextWrapping="Wrap">
                            Note: this requires a working LAN between machines. If the network drops, cross-machine
                            sync is unavailable until connectivity returns.
                        </TextBlock>
                    </StackPanel>

                    <CheckBox x:Name="TopologyEnabledToggle"
                              Content="Enable cross-machine sync"
                              IsCheckedChanged="OnTopologyEnabledChanged" />

                    <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto" Margin="22,0,0,0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine ID:" Foreground="#999" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MachineIdLine" FontFamily="JetBrains Mono,Menlo,Consolas,monospace" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="UDP port:" Foreground="#999" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TopologyPortLine" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Correlation window:" Foreground="#999" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TopologyWindowLine" />
                    </Grid>

                    <TextBlock x:Name="TopologyStatusLine" Margin="22,0,0,0" Foreground="#888" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Diagnostics tab -->
        <TabItem Header="Diagnostics">
            <Grid Margin="8" RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                    <TextBlock Text="System diagnostics" FontSize="16" FontWeight="Bold" />
                    <TextBlock Foreground="#CCC" TextWrapping="Wrap">
                        Full snapshot of everything the app sees: local Bolt receivers, their paired devices,
                        host-slot bindings, firmware versions, battery, plus the network sync state and per-peer health.
                        Refreshes every second. Use "Copy to clipboard" to attach to a support thread.
                    </TextBlock>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer>
                        <SelectableTextBlock x:Name="DiagnosticsText"
                                             Padding="12"
                                             FontFamily="JetBrains Mono,Menlo,Consolas,monospace"
                                             FontSize="12"
                                             TextWrapping="NoWrap"
                                             Text="(loading…)" />
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="Tip: Click anywhere then Cmd/Ctrl+A → Cmd/Ctrl+C to copy" Foreground="#999" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Refresh now" Click="OnRefreshDiagnostics" />
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Updates tab -->
        <TabItem Header="Updates">
            <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="Updates" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                    <TextBlock Text="Current version:" Foreground="#999" />
                    <TextBlock x:Name="CurrentVersionLine" Text="?" />
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                    <TextBlock Text="Last checked:" Foreground="#999" />
                    <TextBlock x:Name="LastCheckedLine" Text="never" />
                </StackPanel>
                <CheckBox Grid.Row="3" x:Name="AutoCheckToggle"
                          Content="Automatically check for updates"
                          IsCheckedChanged="OnAutoCheckChanged" Margin="0,0,0,8" />
                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CheckNowButton" Content="Check now" Click="OnCheckForUpdatesNow" />
                </StackPanel>
                <TextBlock Grid.Row="5" x:Name="UpdateStatusLine"
                           Margin="0,12,0,0" Foreground="#CCC" TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <!-- License tab -->
        <TabItem Header="License">
            <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="License" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                <TextBlock Grid.Row="1" x:Name="LicenseStatusLine" Margin="0,0,0,12" Foreground="#CCC" />
                <TextBlock Grid.Row="2" Text="License key" Margin="0,0,0,4" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="LicenseKeyBox" Width="320" PlaceholderText="Paste your key here" />
                    <Button Content="Apply" Click="OnApplyLicense" />
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
